{"pageProps":{"books":[{"id":"rmrb","name":"人民日报","internal":false,"official":false,"type":"db","author":"","files":[],"article":{"title":"日共总书记宫本显治等到京","authors":[],"dates":[{"year":1959,"month":2,"day":24}],"is_range_date":false,"parts":[{"type":"paragraph","text":"日共总书记宫本显治等到京"},{"type":"paragraph","text":"新华社23日讯　日本共产党总书记宫本显治、日共中央干部会委员春日正一、调查部副部长西泽富夫，今天从莫斯科乘飞机到达北京，来中国进行访问。到机场欢迎的有：中共中央总书记邓小平、政治局委员彭真、书记处书记王稼祥和中央委员伍修权等。"}],"comments":[],"comment_pivots":[],"description":"","page_start":1,"page_end":1,"alias":""},"tags":[{"type":"文稿类型","name":"文章"}]}]},"__N_SSG":true}
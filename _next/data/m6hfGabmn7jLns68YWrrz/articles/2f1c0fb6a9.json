{"pageProps":{"article":{"id":"2f1c0fb6a9","title":"周恩来给江青的信","origin":"","is_range_date":false,"dates":[{"id":"2f93f71eac","index":0,"year":1966,"month":9,"day":20,"articleId":"2f1c0fb6a9"}],"tags":[{"id":"1ffce755c0","name":"工商交通和财政","type":"主题"},{"id":"2a70b5d939","name":"书信","type":"文稿类型"},{"id":"523bb79e8f","name":"周恩来","type":"人物"},{"id":"a2debaee78","name":"农村和农业生产","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"307f1a7663","type":"title","text":"周恩来给江青的信","index":0,"publicationId":"wenku","articleId":"2f1c0fb6a9"},{"id":"91e0ce2f99","type":"paragraph","text":"〖十六日，周恩来将李先念起草的《关于财政贸易和手工业方面若干政策问题的报告》批送中央文革小组批阅。〗","index":1,"publicationId":"wenku","articleId":"2f1c0fb6a9"},{"id":"b2edf5569d","type":"paragraph","text":"文化革命中有关经济政策方面，农业和工业方面、科研两个通知发出后，对生产很有利。财贸和手工业一个通知修改稿，已送文革小组几天，务请陈伯达同志抓一下，以便议后再提请中央政治局讨论。","index":2,"publicationId":"wenku","articleId":"2f1c0fb6a9"}],"page":{"id":"26b361c0da","publicationId":"wenku","articleId":"2f1c0fb6a9","start":0,"end":0}}}},"__N_SSG":true}
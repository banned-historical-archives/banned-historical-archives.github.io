{"pageProps":{"article":{"id":"c25de4cdb5","title":"在胜利中不要冲昏头脑","origin":"","is_range_date":false,"dates":[{"id":"19595b7610","index":0,"year":1967,"month":3,"day":null,"articleId":"c25de4cdb5"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"120ce2d15d","type":"title","text":"在胜利中不要冲昏头脑","index":0,"publicationId":"wansui5","articleId":"c25de4cdb5"},{"id":"6db47bc82d","type":"paragraph","text":"全国粉碎彭、罗、陆、杨反党集团，粉碎刘、邓资产阶级反动路线，要搞尚未揭开的党内走资本主义道路当权派和顽固坚持资产阶级反动路线的人。有什么理由放松警惕？在胜利中不要冲昏头脑，在胜利中要戒骄戒躁。","index":1,"publicationId":"wansui5","articleId":"c25de4cdb5"}],"page":{"id":"e7eae2f2bd","publicationId":"wansui5","articleId":"c25de4cdb5","start":569,"end":569}}}},"__N_SSG":true}
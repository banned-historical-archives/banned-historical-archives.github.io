{"pageProps":{"article":{"id":"0a1e55c1e3","title":"中央文革关于各地最近不要派人去大寨参观的通知","origin":"","is_range_date":false,"dates":[{"id":"f3415c02a2","index":0,"year":1968,"month":7,"day":14,"articleId":"0a1e55c1e3"}],"tags":[{"id":"056fc2625f","name":"中央文革文件","type":"发行机构"},{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"a2debaee78","name":"农村和农业生产","type":"主题"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"00ed5379b5","type":"title","text":"中央文革关于各地最近不要派人去大寨参观的通知","index":0,"publicationId":"wenku","articleId":"0a1e55c1e3"},{"id":"a2129c99e5","type":"paragraph","text":"各省、市、自治区革命委员会（革筹小组）、军管会、大军区、省军区：","index":1,"publicationId":"wenku","articleId":"0a1e55c1e3"},{"id":"d9e681b91d","type":"paragraph","text":"山西大寨生产大队最近遭受自然灾害，正在紧张地进行抗灾斗争，他们要求各地最近不要派人前去参观，我们同意，请各地转告所属单位。","index":2,"publicationId":"wenku","articleId":"0a1e55c1e3"},{"id":"00aff973ef","type":"paragraph","text":"中央文革","index":3,"publicationId":"wenku","articleId":"0a1e55c1e3"},{"id":"3c65408864","type":"paragraph","text":"一九六八年七月十四日","index":4,"publicationId":"wenku","articleId":"0a1e55c1e3"}],"page":{"id":"e958f64986","publicationId":"wenku","articleId":"0a1e55c1e3","start":0,"end":0}}}},"__N_SSG":true}
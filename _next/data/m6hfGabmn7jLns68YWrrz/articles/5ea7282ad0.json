{"pageProps":{"article":{"id":"5ea7282ad0","title":"关于打人问题","origin":"","is_range_date":false,"dates":[{"id":"24b56cdb87","index":0,"year":1966,"month":8,"day":1,"articleId":"5ea7282ad0"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"maoquanji48","name":"毛泽东全集第48卷","internal":false,"official":true,"type":"pdf","author":"张迪杰","files":"https://raw.githubusercontent.com/banned-historical-archives/banned-historical-archives0/main/mao-quanji/48-OCR.pdf"},{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"maoquanji48":{"comments":[],"contents":[{"id":"6ff7e3bf44","type":"title","text":"关于打人问题","index":0,"publicationId":"maoquanji48","articleId":"5ea7282ad0"},{"id":"ab5688dcdb","type":"paragraph","text":"党的政策不主张打人。但打人也要进行阶级分析，好人打环人活该；环人打好人，好人光荣；好人打好人误会。今后再不许打人。要摆事实讲道理","index":1,"publicationId":"maoquanji48","articleId":"5ea7282ad0"},{"id":"25116393d9","type":"paragraph","text":"在同学间取消保皇派这个名词","index":2,"publicationId":"maoquanji48","articleId":"5ea7282ad0"}],"page":{"id":"7e9ca5d19b","publicationId":"maoquanji48","articleId":"5ea7282ad0","start":446,"end":446}},"wansui5":{"comments":[],"contents":[{"id":"10697bfe50","type":"paragraph","text":"党的政策不主张打人。但打人也要进行阶级分析，好人打坏人活该；坏人打好人，好人光荣；好人打好人误会。今后再不许打人。要摆事实讲道理。","index":1,"publicationId":"wansui5","articleId":"5ea7282ad0"},{"id":"c5cf45faf2","type":"title","text":"关于打人问题","index":0,"publicationId":"wansui5","articleId":"5ea7282ad0"}],"page":{"id":"127a2df80d","publicationId":"wansui5","articleId":"5ea7282ad0","start":511,"end":511}}}},"__N_SSG":true}
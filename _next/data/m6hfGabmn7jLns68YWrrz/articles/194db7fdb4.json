{"pageProps":{"article":{"id":"194db7fdb4","title":"命令","origin":"","is_range_date":false,"dates":[{"id":"ba2a9658dd","index":0,"year":1933,"month":8,"day":8,"articleId":"194db7fdb4"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui1","name":"毛泽东思想万岁(1913-1943卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui1a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui1":{"comments":[],"contents":[{"id":"c05fea6827","type":"title","text":"命令","index":0,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"d5573bc01e","type":"paragraph","text":"于约溪总司令部","index":1,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"d698b96c31","type":"subdate","text":"（一）敌之整个布置见蒋介石八月二号命令，卫另录。龙冈有敌第五师","index":2,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"2e222cbc3c","type":"paragraph","text":"四团五十四师两团（昨日未与我军作战的），加上昨天与我军作战的四十七师五十四师败兵约两团，共尚有敌八团。崇贤方太之蒋蔡部，兴国江背洞之赵欢涛部，青塘古龙冈之孙建仲部均在向我军前进，但明日（九号）不能到达龙冈。","index":3,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"7f84cdc097","type":"paragraph","text":"（二）我军决心以全力消灭龙冈之敌。","index":4,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"75fe6ff5fb","type":"paragraph","text":"（三）攻击龙冈布署如左：","index":5,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"0f3f51dd6d","type":"paragraph","text":"三军及七军任左翼，今夜宿营于兰石，担任攻击龙冈之西北端。三军任右翼，今夜宿营于小别，担任攻击龙冈之东北端。四军任正面，今夜宿营于表湖，担任攻击龙冈之南端。十二军位置于四军之后作总预备队，今夜应宿营于表湖附近。","index":6,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"cdce169ce9","type":"paragraph","text":"各军明晨（九号）四时一律总攻，务于上午十二时以前解决战斗。","index":7,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"6d896a16f1","type":"paragraph","text":"（四）解决战斗后，各军宿营地区分于左；","index":8,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"07d924f1ef","type":"paragraph","text":"三军团及七军在上固、下固、缺家坪一带。","index":9,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"0f669118ea","type":"paragraph","text":"三军在小别。","index":10,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"8a8e313a3a","type":"paragraph","text":"四军在水西、高车、大蕉坑、下车、中塘陂一带。","index":11,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"3785126dcd","type":"paragraph","text":"龙冈圩、表湖、张家车、樊铺一带不驻兵。","index":12,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"cd4200dfc3","type":"subdate","text":"（五）明日上午作战时总部在表湖。作战后至夜间，在龙冈圩区政府（圩","index":13,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"0028fb5b64","type":"paragraph","text":"场的南端），后晨移石路坑。","index":14,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"1f2850c81c","type":"subdate","text":"（六）明日下午七时，各军军长、政治委员、军团总指挥、政治委员均","index":15,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"641353f956","type":"paragraph","text":"到区政府总部开会。","index":16,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"3938f125eb","type":"paragraph","text":"总司令政治委员","index":17,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"e49ea365ca","type":"paragraph","text":"毛泽东","index":18,"publicationId":"wansui1","articleId":"194db7fdb4"},{"id":"0e840b42fa","type":"paragraph","text":"（抄自中国革命军事博物馆）","index":19,"publicationId":"wansui1","articleId":"194db7fdb4"}],"page":{"id":"60e0b54e73","publicationId":"wansui1","articleId":"194db7fdb4","start":210,"end":211}}}},"__N_SSG":true}
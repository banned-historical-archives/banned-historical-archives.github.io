{"pageProps":{"article":{"id":"2fc5d5746f","title":"和抗大第三期毕业学员的谈话","origin":"","is_range_date":false,"dates":[{"id":"b08f0a0209","index":0,"year":1938,"month":9,"day":null,"articleId":"2fc5d5746f"}],"tags":[{"id":"314ad57c4d","name":"对话","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"fc0b263e83","type":"title","text":"和抗大第三期毕业学员的谈话","index":0,"publicationId":"wansui2","articleId":"2fc5d5746f"},{"id":"c7da8e990a","type":"paragraph","text":"你们到抗大来学习，有三个阶段，要上三课：从西安到延安八百里，这是第一课；在学校住窑洞，吃小米，出操上课，这是第二课；现在第二课上完了，但是最重要的还是第三课，这便是到斗争中去学习。","index":1,"publicationId":"wansui2","articleId":"2fc5d5746f"}],"page":{"id":"305ac49ddb","publicationId":"wansui2","articleId":"2fc5d5746f","start":398,"end":398}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"9b4f28ad25","title":"周恩来对驻合肥的第十二军军长李德生的电话指示","origin":"","is_range_date":false,"dates":[{"id":"df035b1c25","index":0,"year":1967,"month":12,"day":10,"articleId":"9b4f28ad25"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"3bff1d2fc6","name":"暴力和武斗","type":"主题"},{"id":"523bb79e8f","name":"周恩来","type":"人物"},{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"d2ddb47c3a","type":"title","text":"周恩来对驻合肥的第十二军军长李德生的电话指示","index":0,"publicationId":"wenku","articleId":"9b4f28ad25"},{"id":"8c4a1250af","type":"paragraph","text":"（李德生报告：芜湖“三筹处”的四个组织冲击部队，抢走枪枝弹药，抢占军管会大楼，使军管会无法办公。）","index":1,"publicationId":"wenku","articleId":"9b4f28ad25"},{"id":"4fa9abd90c","type":"paragraph","text":"以安徽省军管会的名义向这四个组织打、砸、抢、抄的小集团提出书面警告，要他们按照中央“九五”命令，立即停止这种非法行为，将武器封存上交。如仍不听劝告，继续犯法，军管会将执行中央命令，依法处理。","index":2,"publicationId":"wenku","articleId":"9b4f28ad25"}],"page":{"id":"a319c13b20","publicationId":"wenku","articleId":"9b4f28ad25","start":0,"end":0}}}},"__N_SSG":true}
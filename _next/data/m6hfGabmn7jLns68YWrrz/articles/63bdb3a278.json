{"pageProps":{"article":{"id":"63bdb3a278","title":"关于按系统实现革命的大联合的指示","origin":"","is_range_date":false,"dates":[{"id":"5c1fa4e6a4","index":0,"year":1967,"month":10,"day":17,"articleId":"63bdb3a278"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"23c151f631","type":"title","text":"关于按系统实现革命的大联合的指示","index":0,"publicationId":"wansui5","articleId":"63bdb3a278"},{"id":"25c35f3ba9","type":"paragraph","text":"各工厂、各学校、各部门、各企业单位，都必须在革命原则下，按照系统，按照行业，按照班级，实现革命的大联合，以利于促进革命三结合的建立，以利于大批判和各单位斗、批、改的进行，以利于抓革命、促生产、促工作、促战备。","index":1,"publicationId":"wansui5","articleId":"63bdb3a278"},{"id":"33fd3d9511","type":"paragraph","text":"（转引白工 1967 年 10 月工 8 日《人民日报》）","index":2,"publicationId":"wansui5","articleId":"63bdb3a278"}],"page":{"id":"476637ce32","publicationId":"wansui5","articleId":"63bdb3a278","start":657,"end":657}}}},"__N_SSG":true}
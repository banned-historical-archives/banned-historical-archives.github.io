{"pageProps":{"article":{"id":"46d6664ad3","title":"对北京卫戍区关于在大、中学开展军训的两个总结报告的两条批语","origin":"","is_range_date":false,"dates":[{"id":"cdc20fa56d","index":0,"year":1967,"month":2,"day":19,"articleId":"46d6664ad3"}],"tags":[{"id":"3be4d5766f","name":"红卫兵运动","type":"主题"},{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"e2305b9e63","name":"毛泽东","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"bf1df65711","type":"title","text":"对北京卫戍区关于在大、中学开展军训的两个总结报告的两条批语","index":0,"publicationId":"wenku","articleId":"46d6664ad3"},{"id":"60cdf951d8","type":"paragraph","text":"林彪同志：","index":1,"publicationId":"wenku","articleId":"46d6664ad3"},{"id":"5ba41392f9","type":"paragraph","text":"（一）此两件应即转发全国。","index":2,"publicationId":"wenku","articleId":"46d6664ad3"},{"id":"117e2d2210","type":"paragraph","text":"（二）大学中学和小学高年级每年训练一次，每次二十天。上课以后，在军训的二十天中，军训时间每天不要超过四小时，同时学校原课程每天相应减少时间四小时。","index":3,"publicationId":"wenku","articleId":"46d6664ad3"},{"id":"799a9b6c9c","type":"paragraph","text":"（三）党、政、军、民机关，除老年外，中年青年都要实行军训，每年二十天。以上请酌办。都不要发表。各地经验已超过北京。我的批语也有些不适应新情况。因此都不宜发表。","index":4,"publicationId":"wenku","articleId":"46d6664ad3"}],"page":{"id":"46de02b0a9","publicationId":"wenku","articleId":"46d6664ad3","start":0,"end":0}}}},"__N_SSG":true}
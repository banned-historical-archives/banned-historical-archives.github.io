{"pageProps":{"article":{"id":"babc6028e3","title":"对军委办事组转报的一份情况简报的批语","origin":"","is_range_date":false,"dates":[{"id":"116ccac192","index":0,"year":1968,"month":11,"day":14,"articleId":"babc6028e3"}],"tags":[{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"e2305b9e63","name":"毛泽东","type":"主题"}],"aliases":[],"publications":[{"id":"maoquanji50","name":"毛泽东全集第50卷","internal":false,"official":true,"type":"pdf","author":"张迪杰","files":"https://raw.githubusercontent.com/banned-historical-archives/banned-historical-archives0/main/mao-quanji/50-OCR.pdf"},{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"maoquanji50":{"comments":[{"id":"88bddc1590","publicationId":"maoquanji50","articleId":"babc6028e3","index":1,"part_index":-99,"offset":-99,"text":"中共中央军委办事组1968年11月13日向毛泽东等转报的这份情况简报，反映了中国人民解放军某部五连在某地“开枪打死、打伤群众的严重政治事件”和部队领导机关认真查证的情况。1972年五六月份中共中央召开的“批林整风”汇报会议，曾将此件作为会议文件印发。"}],"contents":[{"id":"4e2bcab78a","type":"title","text":"对军委办事组转报的一份情况简报的批语","index":0,"publicationId":"maoquanji50","articleId":"babc6028e3"},{"id":"88bddc1590","type":"paragraph","text":"军队领导不祖护部队所作坏事，替受害人民伸冤，这种态度是国家兴旺的表现","index":1,"publicationId":"maoquanji50","articleId":"babc6028e3"}],"page":{"id":"b0176b06c3","publicationId":"maoquanji50","articleId":"babc6028e3","start":352,"end":352}},"wenku":{"comments":[],"contents":[{"id":"0b05f1be42","type":"paragraph","text":"军队领导不袒护部队所作坏事，替受害人民伸冤，这种态度，是国家兴旺的表现。","index":1,"publicationId":"wenku","articleId":"babc6028e3"},{"id":"3f03245eb9","type":"title","text":"对军委办事组转报的一份情况简报的批语","index":0,"publicationId":"wenku","articleId":"babc6028e3"}],"page":{"id":"7f70fe57f0","publicationId":"wenku","articleId":"babc6028e3","start":0,"end":0}}}},"__N_SSG":true}
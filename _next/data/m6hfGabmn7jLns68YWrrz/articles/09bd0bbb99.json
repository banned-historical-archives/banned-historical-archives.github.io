{"pageProps":{"article":{"id":"09bd0bbb99","title":"中央文革小组关于长沙武斗事件的急电","origin":"","is_range_date":false,"dates":[{"id":"8a6bfe97df","index":0,"year":1967,"month":6,"day":6,"articleId":"09bd0bbb99"}],"tags":[{"id":"3bff1d2fc6","name":"暴力和武斗","type":"主题"},{"id":"b4f67da172","name":"中共中央电报","type":"发行机构"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"d48f0ea3e8","name":"造反运动和派别斗争","type":"主题"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"99f8de54fe","type":"title","text":"中央文革小组关于长沙武斗事件的急电","index":0,"publicationId":"wenku","articleId":"09bd0bbb99"},{"id":"77654dfafa","type":"paragraph","text":"（一九六七年六月六日二十一点二十五分）","index":1,"publicationId":"wenku","articleId":"09bd0bbb99"},{"id":"9957e7a2ab","type":"paragraph","text":"长沙工联：","index":2,"publicationId":"wenku","articleId":"09bd0bbb99"},{"id":"bec30fb39a","type":"paragraph","text":"关于长沙武斗事件，中央文革小组有以下三点建议：","index":3,"publicationId":"wenku","articleId":"09bd0bbb99"},{"id":"916c57ff43","type":"paragraph","text":"一、立即停止武斗，有分歧要用协商的办法解决。","index":4,"publicationId":"wenku","articleId":"09bd0bbb99"},{"id":"56f6d09d78","type":"paragraph","text":"二、请章伯森、梁春阳同志协助湖南军区，制止武斗，并同军区一起参加双方的协商。","index":5,"publicationId":"wenku","articleId":"09bd0bbb99"},{"id":"747155d07b","type":"paragraph","text":"三、严禁打、砸、抢、抄、抓，杀人、放火凶手要拘留法办。","index":6,"publicationId":"wenku","articleId":"09bd0bbb99"},{"id":"4fc6674ba4","type":"paragraph","text":"中央文革小组","index":7,"publicationId":"wenku","articleId":"09bd0bbb99"},{"id":"85e5fcc10a","type":"paragraph","text":"一九六七年六月六日","index":8,"publicationId":"wenku","articleId":"09bd0bbb99"}],"page":{"id":"c261fe1acf","publicationId":"wenku","articleId":"09bd0bbb99","start":0,"end":0}}}},"__N_SSG":true}
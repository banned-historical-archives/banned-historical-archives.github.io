{"pageProps":{"article":{"id":"7d727a9ef9","title":"中共中央关于黄永胜等人离职反省的通知","origin":"","is_range_date":false,"dates":[{"id":"1c077b0cda","index":0,"year":1971,"month":9,"day":29,"articleId":"7d727a9ef9"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"318138ea26","name":"重要党政机构及其衍变","type":"主题"},{"id":"91736a0628","name":"中共中央通知","type":"发行机构"},{"id":"a59dfa2519","name":"各级党政领导人","type":"主题"},{"id":"cce608ea44","name":"林彪","type":"主题"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"f14dea2c65","type":"title","text":"中共中央关于黄永胜等人离职反省的通知","index":0,"publicationId":"wenku","articleId":"7d727a9ef9"},{"id":"d2be99ac83","type":"paragraph","text":"毛主席批示：同意。","index":1,"publicationId":"wenku","articleId":"7d727a9ef9"},{"id":"77b77c027c","type":"paragraph","text":"各大军区党委常委，各省、市、自治区党委常委，军委各总部、各军兵种党委常委，中央和国务院各部委领导小组或党的核心小组（绝密）：","index":2,"publicationId":"wenku","articleId":"7d727a9ef9"},{"id":"e124232c7c","type":"paragraph","text":"中央鉴于黄永胜、吴法宪、李作鹏、邱会作四同志参加林、陈反党集团的宗派活动，陷入很深，实难继续现任工作，已令他们离职反省，彻底交代。","index":3,"publicationId":"wenku","articleId":"7d727a9ef9"},{"id":"cdeb168c6e","type":"paragraph","text":"军委日常工作，中央已决定由军委副主席叶剑英同志主持，并筹组军委办公会议，进行集体领导。","index":4,"publicationId":"wenku","articleId":"7d727a9ef9"},{"id":"f46e6696ce","type":"paragraph","text":"中共中央","index":5,"publicationId":"wenku","articleId":"7d727a9ef9"},{"id":"fbb3eaa0f7","type":"paragraph","text":"一九七一年九月二十九日","index":6,"publicationId":"wenku","articleId":"7d727a9ef9"}],"page":{"id":"c322a49f3f","publicationId":"wenku","articleId":"7d727a9ef9","start":0,"end":0}}}},"__N_SSG":true}
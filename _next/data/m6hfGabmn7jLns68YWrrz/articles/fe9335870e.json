{"pageProps":{"article":{"id":"fe9335870e","title":"关于发生打人事件的指示","origin":"","is_range_date":false,"dates":[{"id":"0e5b0f71c6","index":0,"year":1966,"month":6,"day":null,"articleId":"fe9335870e"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"3bff1d2fc6","name":"暴力和武斗","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"e2305b9e63","name":"毛泽东","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"aabb28b9d0","type":"title","text":"关于发生打人事件的指示","index":0,"publicationId":"wenku","articleId":"fe9335870e"},{"id":"d9410efefe","type":"paragraph","text":"党的政策不主张打人。但对打人也要进行阶级分析，好人打坏人活该；坏人打好人，好人光荣；好人打好人误会。今后不许打人，要摆事实，讲道理。","index":1,"publicationId":"wenku","articleId":"fe9335870e"},{"id":"2f2d84268a","type":"paragraph","text":"在同学中取消保皇派这个名词。","index":2,"publicationId":"wenku","articleId":"fe9335870e"}],"page":{"id":"2e81eca146","publicationId":"wenku","articleId":"fe9335870e","start":0,"end":0}}}},"__N_SSG":true}
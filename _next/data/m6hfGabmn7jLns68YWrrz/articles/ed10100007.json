{"pageProps":{"article":{"id":"ed10100007","title":"致湖南省警察厅长的公开信（摘录）","origin":"","is_range_date":false,"dates":[{"id":"c4a00ecefc","index":0,"year":1920,"month":12,"day":null,"articleId":"ed10100007"}],"tags":[{"id":"5bfa9ca15d","name":"宣言","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui1","name":"毛泽东思想万岁(1913-1943卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui1a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui1":{"comments":[],"contents":[{"id":"c8738062e1","type":"title","text":"致湖南省警察厅长的公开信（摘录）","index":0,"publicationId":"wansui1","articleId":"ed10100007"},{"id":"762eea2e09","type":"paragraph","text":"对于湖南自治，认为关系湖南人民死生荣辱，曾为学理上之主张，亦曾随众人作为事实上之促进，所谓制宪建设是也。事实绝对公开，并无丝毫隐秘......泽东为新湖南之自由民，除依法律，无论何人，不得于我之身体及名誉有丝毫侵犯。","index":1,"publicationId":"wansui1","articleId":"ed10100007"},{"id":"db8cfe856b","type":"paragraph","text":"（原范长沙《大公报》1920 年 12 月 5 日）","index":2,"publicationId":"wansui1","articleId":"ed10100007"}],"page":{"id":"961dfa8f29","publicationId":"wansui1","articleId":"ed10100007","start":101,"end":101}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"2ace31bb1b","title":"关于游泳的指示","origin":"","is_range_date":false,"dates":[{"id":"dbec6eb4cf","index":0,"year":1958,"month":9,"day":null,"articleId":"2ace31bb1b"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui4","name":"毛泽东思想万岁(1958-1960卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui4a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui4":{"comments":[],"contents":[{"id":"679efd022b","type":"title","text":"关于游泳的指示","index":0,"publicationId":"wansui4","articleId":"2ace31bb1b"},{"id":"d3cd760943","type":"paragraph","text":"“你们不要老在游泳池里面练，游泳池小。游来游去就那么一点，要多到江河里去练习。”","index":1,"publicationId":"wansui4","articleId":"2ace31bb1b"},{"id":"52326ce44a","type":"paragraph","text":"“要走出游泳池。”","index":2,"publicationId":"wansui4","articleId":"2ace31bb1b"},{"id":"e7960276d6","type":"paragraph","text":"“在江河游泳，有逆流，可以锻炼意志和勇敢。”","index":3,"publicationId":"wansui4","articleId":"2ace31bb1b"},{"id":"577464ee00","type":"paragraph","text":"（注：毛主席 1958 年 9 月 12 日在武汉和游泳运动员的谈话）","index":4,"publicationId":"wansui4","articleId":"2ace31bb1b"},{"id":"39494084ed","type":"paragraph","text":"“游泳是一项很好的运动，应该提倡。”","index":5,"publicationId":"wansui4","articleId":"2ace31bb1b"},{"id":"cdad53f863","type":"paragraph","text":"（注：毛主席 1958 年 9 月在安徽和游泳运动员的谈话）","index":6,"publicationId":"wansui4","articleId":"2ace31bb1b"}],"page":{"id":"898f63afd6","publicationId":"wansui4","articleId":"2ace31bb1b","start":252,"end":252}}}},"__N_SSG":true}
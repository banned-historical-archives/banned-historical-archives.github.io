{"pageProps":{"article":{"id":"ee0d29daeb","title":"陶铸给陶鲁笳的一封信","origin":"","is_range_date":false,"dates":[{"id":"16cc1d0caf","index":0,"year":1966,"month":8,"day":22,"articleId":"ee0d29daeb"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"dbcf15bd08","name":"陶铸","type":"人物"},{"id":"f68680a40d","name":"大串联","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"489fec27f2","name":"陶铸"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"ac6f944fcc","type":"title","text":"陶铸给陶鲁笳的一封信","index":0,"publicationId":"wenku","articleId":"ee0d29daeb"},{"id":"c1555cd2da","type":"paragraph","text":"陶鲁笳同志：","index":1,"publicationId":"wenku","articleId":"ee0d29daeb"},{"id":"279acbf18f","type":"paragraph","text":"我昨天主要是针对中南地区文化革命尚未搞起来，而讲的一些问题。其中关于外地同学来京取经和北京学生去外地支援的讲话，精神是与《人民日报》社论完全一致的，只是重点不同，详细内容摘要秘书在电话中告诉你。望转告各学校文革筹委会为盼！","index":2,"publicationId":"wenku","articleId":"ee0d29daeb"},{"id":"6a69fecc0f","type":"paragraph","text":"敬礼","index":3,"publicationId":"wenku","articleId":"ee0d29daeb"},{"id":"0c10b2d9b8","type":"paragraph","text":"陶铸","index":4,"publicationId":"wenku","articleId":"ee0d29daeb"},{"id":"c75f00a5df","type":"paragraph","text":"八月二十二日","index":5,"publicationId":"wenku","articleId":"ee0d29daeb"}],"page":{"id":"6e59bb994a","publicationId":"wenku","articleId":"ee0d29daeb","start":0,"end":0}}}},"__N_SSG":true}
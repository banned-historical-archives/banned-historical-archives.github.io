{"pageProps":{"article":{"id":"c6609b5fd7","title":"周恩来给喀什问题调查团来电指示要点","origin":"","is_range_date":false,"dates":[{"id":"11df51e0ee","index":0,"year":1967,"month":10,"day":13,"articleId":"c6609b5fd7"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"3bff1d2fc6","name":"暴力和武斗","type":"主题"},{"id":"523bb79e8f","name":"周恩来","type":"人物"},{"id":"c0cd6cf1d4","name":"边境地区和少数民族","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"3756d7d455","type":"title","text":"周恩来给喀什问题调查团来电指示要点","index":0,"publicationId":"wenku","articleId":"c6609b5fd7"},{"id":"be1a0d7ada","type":"paragraph","text":"〖时间：北京时间凌晨三时。来电从武汉发出。喀什问题调查团由新疆军区、七三三五部队红二司组成。〗","index":1,"publicationId":"wenku","articleId":"c6609b5fd7"},{"id":"6fb95fad41","type":"paragraph","text":"一、无条件开放交通，以前没有下命令，这次要给你们下命令；","index":2,"publicationId":"wenku","articleId":"c6609b5fd7"},{"id":"c830dd0ebb","type":"paragraph","text":"二、八野、四野的武器立即收交，群众组织的武器由自己统一封存，今后喀什由七三三五部队负责监督；","index":3,"publicationId":"wenku","articleId":"c6609b5fd7"},{"id":"968fd54e71","type":"paragraph","text":"三、到晨六时（北京时间）将工事全部拆除，并向空军司令员吴法宪同志汇报。","index":4,"publicationId":"wenku","articleId":"c6609b5fd7"},{"id":"db96e3ada8","type":"paragraph","text":"抄自《四一八通讯》一九六七年十月十四日","index":5,"publicationId":"wenku","articleId":"c6609b5fd7"},{"id":"fb815e4eac","type":"paragraph","text":"（注）喀什造反派坚决执行总理指示，在晨六时前将自己的防卫工事全部拆除。","index":6,"publicationId":"wenku","articleId":"c6609b5fd7"}],"page":{"id":"625ad4e134","publicationId":"wenku","articleId":"c6609b5fd7","start":0,"end":0}}}},"__N_SSG":true}
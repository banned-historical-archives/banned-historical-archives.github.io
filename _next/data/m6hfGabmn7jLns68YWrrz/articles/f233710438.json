{"pageProps":{"article":{"id":"f233710438","title":"周恩来关于新疆喀什问题给七三三五部队的指示","origin":"","is_range_date":false,"dates":[{"id":"aa9250fb6e","index":0,"year":1967,"month":10,"day":6,"articleId":"f233710438"}],"tags":[{"id":"1ffce755c0","name":"工商交通和财政","type":"主题"},{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"523bb79e8f","name":"周恩来","type":"人物"},{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"4df601b053","type":"title","text":"周恩来关于新疆喀什问题给七三三五部队的指示","index":0,"publicationId":"wenku","articleId":"f233710438"},{"id":"b5c818c9e2","type":"paragraph","text":"总理给七三三五部队派往喀什解决问题的孟昭远同志来电指示（摘自电话纪录）：","index":1,"publicationId":"wenku","articleId":"f233710438"},{"id":"50affabe80","type":"paragraph","text":"“喀什地处边疆，是反修斗争前哨，必须保持社会秩序的稳定。因此，要坚决贯彻《六·六通令》、《九·五命令》。当地的公路交通不允许任何人阻碍破坏，谁要设路卡、路障、破坏交通，要对该组织负责人查处。……你（指孟昭远同志）就代表我们中央监督他们双方执行。”","index":2,"publicationId":"wenku","articleId":"f233710438"}],"page":{"id":"3c90b4e145","publicationId":"wenku","articleId":"f233710438","start":0,"end":0}}}},"__N_SSG":true}
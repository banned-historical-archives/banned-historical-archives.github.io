{"pageProps":{"article":{"id":"7d380644ef","title":"中央文革关于勒令福州《北京》刊物停刊的通报","origin":"","is_range_date":false,"dates":[{"id":"036c0636a9","index":0,"year":1967,"month":12,"day":23,"articleId":"7d380644ef"}],"tags":[{"id":"1ffce755c0","name":"工商交通和财政","type":"主题"},{"id":"268718f23b","name":"新闻广播和出版","type":"主题"},{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"3be4d5766f","name":"红卫兵运动","type":"主题"},{"id":"94b82e4994","name":"中共中央决定、指示等","type":"发行机构"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"93014631ca","type":"title","text":"中央文革关于勒令福州《北京》刊物停刊的通报","index":0,"publicationId":"wenku","articleId":"7d380644ef"},{"id":"ecdcc7b51d","type":"paragraph","text":"福建军管会并各省、市、自治区革命委员会（筹备小组）、军管会、各大军区、省军区：","index":1,"publicationId":"wenku","articleId":"7d380644ef"},{"id":"07112921e6","type":"paragraph","text":"福州发行的名为《北京》的刊物上，擅自大量刊登没有公开发表的，未经核实的中央负责同志的讲话和中共中央文件。中央认为，这种做法是完全错误的。此刊物应立即停刊，并把过去已出版的二十九期送十套交中央文革审查。","index":2,"publicationId":"wenku","articleId":"7d380644ef"}],"page":{"id":"62c227f77e","publicationId":"wenku","articleId":"7d380644ef","start":0,"end":0}}}},"__N_SSG":true}
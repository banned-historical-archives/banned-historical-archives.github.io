{"pageProps":{"article":{"id":"60e0c095b7","title":"进行教育革命要依靠无产阶级革命派","origin":"","is_range_date":false,"dates":[{"id":"00694dfd49","index":0,"year":1967,"month":10,"day":25,"articleId":"60e0c095b7"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"f4ba0f3d45","type":"title","text":"进行教育革命要依靠无产阶级革命派","index":0,"publicationId":"wansui5","articleId":"60e0c095b7"},{"id":"9b11e5e2b6","type":"paragraph","text":"进行无产阶级教育革命，要依靠学校中广大革命的学生，革命的教员，革命的工人要依靠他们中间的积极分子，即决心把无产阶级文化大革命进行到底的无产阶级革命派。","index":1,"publicationId":"wansui5","articleId":"60e0c095b7"},{"id":"736f625849","type":"paragraph","text":"（转引自 1967 年 10 月 27 日《人民日报》在发表《关于教育革命的几个初步方案》时所加的“编者按”。）","index":2,"publicationId":"wansui5","articleId":"60e0c095b7"}],"page":{"id":"45cdcf1d0a","publicationId":"wansui5","articleId":"60e0c095b7","start":658,"end":658}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"dea546898e","title":"关于《海瑞罢官》","origin":"","is_range_date":false,"dates":[{"id":"a65ed06942","index":0,"year":1966,"month":2,"day":8,"articleId":"dea546898e"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"7f3cc476cb","type":"title","text":"关于《海瑞罢官》","index":0,"publicationId":"wansui5","articleId":"dea546898e"},{"id":"f72da70a81","type":"paragraph","text":"吴晗的《海瑞罢官》的要害是罢官，是同庐山会议、同彭德怀的右倾机会主义有关的。","index":1,"publicationId":"wansui5","articleId":"dea546898e"},{"id":"da09b43327","type":"paragraph","text":"对资产阶级意识形态的斗争，是长期的阶级斗争，绝不是匆促做一个政治结论就可以解决的。","index":2,"publicationId":"wansui5","articleId":"dea546898e"},{"id":"f2242663e7","type":"paragraph","text":"〔彭真说要对左派“整风”〕这样的问题，三年以后再说。","index":3,"publicationId":"wansui5","articleId":"dea546898e"}],"page":{"id":"bb2a563a19","publicationId":"wansui5","articleId":"dea546898e","start":482,"end":482}}}},"__N_SSG":true}
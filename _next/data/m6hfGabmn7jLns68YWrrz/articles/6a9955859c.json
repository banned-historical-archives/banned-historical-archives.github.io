{"pageProps":{"article":{"id":"6a9955859c","title":"关于军队支持左派的指示","origin":"","is_range_date":false,"dates":[{"id":"e494f4a2f3","index":0,"year":1967,"month":1,"day":21,"articleId":"6a9955859c"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"c66e20c45a","type":"title","text":"关于军队支持左派的指示","index":0,"publicationId":"wansui5","articleId":"6a9955859c"},{"id":"5e5782c37d","type":"paragraph","text":"林彪同志：","index":1,"publicationId":"wansui5","articleId":"6a9955859c"},{"id":"aa9c6b6794","type":"paragraph","text":"应派军队支持左派广大群众。请酌处。","index":2,"publicationId":"wansui5","articleId":"6a9955859c"},{"id":"e0115b05be","type":"paragraph","text":"毛泽东","index":3,"publicationId":"wansui5","articleId":"6a9955859c"},{"id":"979d0d92a1","type":"paragraph","text":"一九六七年元月二十一日","index":4,"publicationId":"wansui5","articleId":"6a9955859c"},{"id":"590a93417e","type":"paragraph","text":"以后，凡有真正革命派要求军队支持援助，都应该这样做。所谓不介入是假的，早已介入了。此事似应重新发布命令，以前命令作废。请酌。又及。","index":5,"publicationId":"wansui5","articleId":"6a9955859c"}],"page":{"id":"61f741aaeb","publicationId":"wansui5","articleId":"6a9955859c","start":547,"end":547}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"429f752c3b","title":"中央军委关于解放军艺术学院学生参加“湘江风雷”的通知","origin":"","is_range_date":false,"dates":[{"id":"501da10368","index":0,"year":1967,"month":2,"day":9,"articleId":"429f752c3b"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"d125b2a9b6","name":"中央军委文件","type":"发行机构"},{"id":"d48f0ea3e8","name":"造反运动和派别斗争","type":"主题"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"dd2ebaa3cf","type":"title","text":"中央军委关于解放军艺术学院学生参加“湘江风雷”的通知","index":0,"publicationId":"wenku","articleId":"429f752c3b"},{"id":"f58c2711d1","type":"paragraph","text":"最近在湖南长沙，解放军艺术学院三人参加了反动组织“湘江风雷”，进行反革命活动，还有部分学生特别是艺院“星火燎原”在湖南、沈阳、福州等军区造谣，抄家，任意抓人，带头冲击军事领导机关，进行残酷武斗，抗拒毛主席批准的八条命令。为了坚决贯彻毛主席的指示，以护军纪，保卫文化大革命，军委决定：艺术学院所有人员，限五天之内返回本校进行整风，违者以军纪处分。","index":1,"publicationId":"wenku","articleId":"429f752c3b"},{"id":"592f612163","type":"paragraph","text":"中央军委","index":2,"publicationId":"wenku","articleId":"429f752c3b"},{"id":"0924342926","type":"paragraph","text":"一九六七年二月九日","index":3,"publicationId":"wenku","articleId":"429f752c3b"}],"page":{"id":"84d54ab1f7","publicationId":"wenku","articleId":"429f752c3b","start":0,"end":0}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"109697337b","title":"中共中央政治局扩大会议决定","origin":"","is_range_date":false,"dates":[{"id":"335c20d822","index":0,"year":1966,"month":5,"day":23,"articleId":"109697337b"}],"tags":[{"id":"83b1479e48","name":"重要党内斗争和案件","type":"主题"},{"id":"94b82e4994","name":"中共中央决定、指示等","type":"发行机构"},{"id":"afdf5cd1a7","name":"重要会议","type":"主题"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"5956cb2987","type":"title","text":"中共中央政治局扩大会议决定","index":0,"publicationId":"wenku","articleId":"109697337b"},{"id":"1ef74615c1","type":"paragraph","text":"（一）停止彭真同志、陆定一同志、罗瑞卿同志的中央书记处书记的职务，停止杨尚昆同志的中央书记处候补书记的职务，以后提请中央全会追认和决定。","index":1,"publicationId":"wenku","articleId":"109697337b"},{"id":"d860ac7d4d","type":"paragraph","text":"（二）撤销彭真同志的北京市委第一书记和市长的职务；撤销陆定一同志的中央宣传部部长的职务。","index":2,"publicationId":"wenku","articleId":"109697337b"},{"id":"d2443def3c","type":"paragraph","text":"（三）调陶铸同志担任中央书记处常务书记，并兼任中央宣传部部长；调叶剑英同志担任中央书记处书记，并兼任中央军委秘书长。他们的中央书记处书记的职务，以后提请中央全会追认和决定。","index":3,"publicationId":"wenku","articleId":"109697337b"},{"id":"36df666426","type":"paragraph","text":"（四）李雪峰同志兼任北京市委第一书记。","index":4,"publicationId":"wenku","articleId":"109697337b"},{"id":"f19078267d","type":"paragraph","text":"（五）上述决定，地方通知到县委以上，军队通知到团级以上。","index":5,"publicationId":"wenku","articleId":"109697337b"}],"page":{"id":"97dc7df3fd","publicationId":"wenku","articleId":"109697337b","start":0,"end":0}}}},"__N_SSG":true}
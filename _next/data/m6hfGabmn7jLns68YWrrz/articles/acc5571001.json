{"pageProps":{"article":{"id":"acc5571001","title":"教育要彻底改革","origin":"","is_range_date":false,"dates":[{"id":"8764b79b74","index":0,"year":1967,"month":7,"day":null,"articleId":"acc5571001"}],"tags":[{"id":"299424f798","name":"教育和教育革命","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"07d86be162","type":"title","text":"教育要彻底改革","index":0,"publicationId":"wenku","articleId":"acc5571001"},{"id":"db0f69238f","type":"paragraph","text":"（大学斗批改）一种可能是彻底翻身，一种可能是走回头路，一种可能是改良，就看能否在下阶段打硬仗了。","index":1,"publicationId":"wenku","articleId":"acc5571001"},{"id":"3e57ffc0f0","type":"paragraph","text":"斗批就是破，改就是立。这次教育革命一定要彻底改革，否则是改良，和过去一样，到后来是改不下去的。","index":2,"publicationId":"wenku","articleId":"acc5571001"}],"page":{"id":"cb2691091f","publicationId":"wenku","articleId":"acc5571001","start":0,"end":0}}}},"__N_SSG":true}
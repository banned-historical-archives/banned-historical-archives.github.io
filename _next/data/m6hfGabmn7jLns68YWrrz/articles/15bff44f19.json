{"pageProps":{"article":{"id":"15bff44f19","title":"周恩来关于不准占领郑州邮电大楼的指示","origin":"","is_range_date":false,"dates":[{"id":"00daf0082c","index":0,"year":1967,"month":6,"day":28,"articleId":"15bff44f19"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"3bff1d2fc6","name":"暴力和武斗","type":"主题"},{"id":"523bb79e8f","name":"周恩来","type":"人物"},{"id":"53b954d860","name":"公安与法律","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"9d065ef1cc","type":"title","text":"周恩来关于不准占领郑州邮电大楼的指示","index":0,"publicationId":"wenku","articleId":"15bff44f19"},{"id":"42cb2ccc2c","type":"paragraph","text":"〖六月二十八日晚总理联络员李杰同志传达〗","index":1,"publicationId":"wenku","articleId":"15bff44f19"},{"id":"b67b24de0b","type":"paragraph","text":"郑州邮电大楼是重要交通电讯枢纽，一旦中断，严重影响国内国际斗争，工作甚巨。不管那一派革命群众组织，必须确保该机关的安全和正常的工作秩序，不准随便占领和干扰，更不准打、砸、抢，必须严格按照中央六月六日通令执行。","index":2,"publicationId":"wenku","articleId":"15bff44f19"}],"page":{"id":"9e895731cb","publicationId":"wenku","articleId":"15bff44f19","start":0,"end":0}}}},"__N_SSG":true}
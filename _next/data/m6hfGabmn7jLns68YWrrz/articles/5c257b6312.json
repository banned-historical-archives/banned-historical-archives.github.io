{"pageProps":{"article":{"id":"5c257b6312","title":"《新青年》第七卷第一号","origin":"","is_range_date":false,"dates":[{"id":"d82e1615e8","index":0,"year":1917,"month":null,"day":null,"articleId":"5c257b6312"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui1","name":"毛泽东思想万岁(1913-1943卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui1a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui1":{"comments":[],"contents":[{"id":"ad396e1eef","type":"title","text":"《新青年》第七卷第一号","index":0,"publicationId":"wansui1","articleId":"5c257b6312"},{"id":"6671e356db","type":"paragraph","text":"长沙受了“五四”运动的鼓动，一般人向新潮方面定的，实在不少，又因近年来屡受军阀派的摧残，弄得长沙这锦绣的地方，常常没有一点生气，于是一般稍有知识的人-一各校教职员及学生——莫不深深痛恨。更觉得这《社会改造》、《思想革新》、《妇女解放》、《民族自决》种种问题万不容缓。","index":1,"publicationId":"wansui1","articleId":"5c257b6312"}],"page":{"id":"d6ae8008fc","publicationId":"wansui1","articleId":"5c257b6312","start":10,"end":10}}}},"__N_SSG":true}
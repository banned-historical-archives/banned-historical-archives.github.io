{"pageProps":{"article":{"id":"8affb98a45","title":"为纠正“左”的错误给中央局的信","origin":"","is_range_date":false,"dates":[{"id":"cc9e1280d2","index":0,"year":1948,"month":1,"day":20,"articleId":"8affb98a45"}],"tags":[{"id":"2a70b5d939","name":"书信","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"0e080e5762","type":"title","text":"为纠正“左”的错误给中央局的信","index":0,"publicationId":"wansui2","articleId":"8affb98a45"},{"id":"6879e9255d","type":"paragraph","text":"（上略）我完全同意习××的这些意见。华北华中各地老解放区如有同样情形者，必须密切注意改正。凡犯有“左”的错误的地方，领导机关千万不要拖延很久才去纠正，只要处理得法，几个星期就可以纠正过来的。但纠正时，必须注意，不要使下面因纠正“左”的错误而误认为不要动了。","index":1,"publicationId":"wansui2","articleId":"8affb98a45"}],"page":{"id":"c42fa2ac59","publicationId":"wansui2","articleId":"8affb98a45","start":180,"end":180}}}},"__N_SSG":true}
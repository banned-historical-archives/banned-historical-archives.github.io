{"pageProps":{"article":{"id":"c1c15bd528","title":"复栗裕等电","origin":"","is_range_date":false,"dates":[{"id":"a6ba3db29f","index":0,"year":1949,"month":8,"day":2,"articleId":"c1c15bd528"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"maoquanji27","name":"毛泽东全集第27卷","internal":false,"official":true,"type":"pdf","author":"张迪杰","files":"https://raw.githubusercontent.com/banned-historical-archives/banned-historical-archives0/main/mao-quanji/27-OCR.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"maoquanji27":{"comments":[{"id":"05819e3616","publicationId":"maoquanji27","articleId":"c1c15bd528","index":1,"part_index":-99,"offset":-99,"text":"这是毛泽东为中共中央军委起草的复票裕并告华东局电的主要内容。张爱萍，当时任华东军区海军司令员兼政治委员。"}],"contents":[{"id":"d3e884a39b","type":"title","text":"复栗裕等电\"","index":0,"publicationId":"maoquanji27","articleId":"c1c15bd528"},{"id":"05819e3616","type":"paragraph","text":"同意三十日电意见，张爱萍海军系统暂时不迁青岛，并仍归华东系统即归菜裕指挥。你们积极准备攻台湾是正确的。必须从各方面准备攻台，打破干部中的畏难心理","index":1,"publicationId":"maoquanji27","articleId":"c1c15bd528"},{"id":"8dfc6f875d","type":"paragraph","text":"1949年8月，毛泽东在中南海接见人民海军初创人员。","index":2,"publicationId":"maoquanji27","articleId":"c1c15bd528"}],"page":{"id":"bd85c4c746","publicationId":"maoquanji27","articleId":"c1c15bd528","start":105,"end":105}}}},"__N_SSG":true}
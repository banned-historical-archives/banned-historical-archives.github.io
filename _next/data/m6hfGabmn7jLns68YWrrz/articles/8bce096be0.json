{"pageProps":{"article":{"id":"8bce096be0","title":"和林彪同志的一段谈话（摘录）","origin":"","is_range_date":false,"dates":[],"tags":[{"id":"314ad57c4d","name":"对话","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"2aad9526b5","type":"title","text":"和林彪同志的一段谈话（摘录）","index":0,"publicationId":"wansui5","articleId":"8bce096be0"},{"id":"7e39d3c136","type":"paragraph","text":"林彪：现在全国都在深入学习毛主席著作。","index":1,"publicationId":"wansui5","articleId":"8bce096be0"},{"id":"560af53a6e","type":"paragraph","text":"毛主席：我不愿照抄照传，要突破，不要迷信，要有新的论点，新的创造。","index":2,"publicationId":"wansui5","articleId":"8bce096be0"},{"id":"d68954a072","type":"paragraph","text":"林彪：要以毛泽东思想作种子。","index":3,"publicationId":"wansui5","articleId":"8bce096be0"},{"id":"cdfe5d4b91","type":"paragraph","text":"毛主席：好。","index":4,"publicationId":"wansui5","articleId":"8bce096be0"},{"id":"f923f599b1","type":"paragraph","text":"林彪：不能满足于经济建设，要搞精神建设。","index":5,"publicationId":"wansui5","articleId":"8bce096be0"}],"page":{"id":"f227a59f9c","publicationId":"wansui5","articleId":"8bce096be0","start":542,"end":542}}}},"__N_SSG":true}
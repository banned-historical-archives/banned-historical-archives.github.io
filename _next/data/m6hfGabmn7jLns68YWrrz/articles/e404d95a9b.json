{"pageProps":{"article":{"id":"e404d95a9b","title":"批示×××在农村蹲点至少五个月","origin":"","is_range_date":false,"dates":[{"id":"1944643f30","index":0,"year":1963,"month":6,"day":3,"articleId":"e404d95a9b"}],"tags":[{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"8ab6c8001b","type":"title","text":"批示×××在农村蹲点至少五个月","index":0,"publicationId":"wansui5","articleId":"e404d95a9b"},{"id":"14bf4ff528","type":"paragraph","text":"（写在中央工作会议简报李雪峰同志发言上面）","index":1,"publicationId":"wansui5","articleId":"e404d95a9b"},{"id":"0a4764057b","type":"paragraph","text":"此件送×××一阅，阅后退我。","index":2,"publicationId":"wansui5","articleId":"e404d95a9b"},{"id":"1d7e58e9c0","type":"paragraph","text":"你应当下决心在今冬明春这段期间，在北京农村地区或天津郊区蹲点，至少五个月。家里工作可以间接或抽时间回来处理。从新华社和人民日报抽出一批人相当地干部合组一个工作队，包一个最坏的人民公社，一直把工作做完，以后并成为你们经常联系的一个点。还要在一个冬春，参加城市五反。千万不要放弃参加这次伟大革命的机会。","index":3,"publicationId":"wansui5","articleId":"e404d95a9b"},{"id":"a9bbf68d51","type":"paragraph","text":"毛泽东","index":4,"publicationId":"wansui5","articleId":"e404d95a9b"}],"page":{"id":"5b9628019e","publicationId":"wansui5","articleId":"e404d95a9b","start":116,"end":116}}}},"__N_SSG":true}
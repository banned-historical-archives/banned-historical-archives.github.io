{"pageProps":{"article":{"id":"ab1eac71fc","title":"陶琦在交通部的讲话","origin":"","is_range_date":false,"dates":[{"id":"0c0b375f25","index":0,"year":1975,"month":null,"day":null,"articleId":"ab1eac71fc"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"d961340868","name":"航空与航运","type":"主题"},{"id":"e23dcf99fa","name":"发言","type":"文稿类型"},{"id":"f6efa752f4","name":"陶琦","type":"人物"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"8e8de89eea","name":"陶琦"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"394395e4f6","type":"title","text":"陶琦在交通部的讲话","index":0,"publicationId":"wenku","articleId":"ab1eac71fc"},{"id":"2fe7382135","type":"paragraph","text":"前几天部里研究长江问题时，算了一笔大帐。近十年来，国家投资，人员成倍增加，但产量、吨位增长幅度小，吨·公里下降。对天津港和新港船厂作了分析，虽然产量有所上升，但与人员，设备增加数相比，也是慢的。……搞得不好，就叫鼓足干劲，力争下游，少慢差费。","index":1,"publicationId":"wenku","articleId":"ab1eac71fc"}],"page":{"id":"e800d8b6b9","publicationId":"wenku","articleId":"ab1eac71fc","start":0,"end":0}}}},"__N_SSG":true}
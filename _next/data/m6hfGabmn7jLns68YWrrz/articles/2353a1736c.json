{"pageProps":{"article":{"id":"2353a1736c","title":"电复海外侨团答复对中共五一时局主张的响应","origin":"","is_range_date":false,"dates":[{"id":"c871caaaa8","index":0,"year":1948,"month":10,"day":1,"articleId":"2353a1736c"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"f22aaee9e7","type":"title","text":"电复海外侨团答复对中共五一时局主张的响应","index":0,"publicationId":"wansui2","articleId":"2353a1736c"},{"id":"db53cedafc","type":"paragraph","text":"陈嘉庚先生并请转各地侨胞民主团体及一切主张民主的侨胞公鉴：","index":1,"publicationId":"wansui2","articleId":"2353a1736c"},{"id":"c6587238c6","type":"paragraph","text":"五月四日新加坡侨团来电南洋各地侨团函电，因交通阻隔，今始奉悉。诸先生关怀祖国，赞成敝党五月一日对时局主张，热心卓见，无以感佩。诸先生与各界侨胞对于召集新政治协商会议的各项具体意见，尚望随时电示，以利进行，实深企朌。","index":2,"publicationId":"wansui2","articleId":"2353a1736c"},{"id":"1a7f31e408","type":"paragraph","text":"中国共产党中央委员会","index":3,"publicationId":"wansui2","articleId":"2353a1736c"},{"id":"a33234a64a","type":"paragraph","text":"毛泽东","index":4,"publicationId":"wansui2","articleId":"2353a1736c"},{"id":"eac3b96e35","type":"paragraph","text":"（原载《人民日报》一九四八年十月五日）","index":5,"publicationId":"wansui2","articleId":"2353a1736c"}],"page":{"id":"893c6a08ba","publicationId":"wansui2","articleId":"2353a1736c","start":217,"end":217}}}},"__N_SSG":true}
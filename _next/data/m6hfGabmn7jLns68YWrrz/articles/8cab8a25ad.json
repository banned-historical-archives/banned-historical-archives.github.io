{"pageProps":{"article":{"id":"8cab8a25ad","title":"邓小平在文化部有关《人民文学》的请示报告上的批示","origin":"","is_range_date":false,"dates":[{"id":"88b4d82524","index":0,"year":1975,"month":9,"day":8,"articleId":"8cab8a25ad"}],"tags":[{"id":"5387dec24b","name":"文学艺术","type":"主题"},{"id":"5bd9678625","name":"邓小平","type":"人物"},{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"f0e44655bb","name":"邓小平"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"cc083e83c0","type":"title","text":"邓小平在文化部有关《人民文学》的请示报告上的批示","index":0,"publicationId":"wenku","articleId":"8cab8a25ad"},{"id":"b7b2413fe2","type":"paragraph","text":"〖一九七五年八月二十五日张春桥召集文化部领导人谈话，就《人民文学》复刊一事指示：“要夺权，不要原来的班子。”九月六日，文化部“创办《人民文学》”的报告送交政治局。八日，张春桥批示：“拟原则同意”。〗","index":1,"publicationId":"wenku","articleId":"8cab8a25ad"},{"id":"1a0a65c570","type":"paragraph","text":"我赞成。看来现在这个文化部领导办好这个刊物，不容易。","index":2,"publicationId":"wenku","articleId":"8cab8a25ad"}],"page":{"id":"de0a4f9241","publicationId":"wenku","articleId":"8cab8a25ad","start":0,"end":0}}}},"__N_SSG":true}
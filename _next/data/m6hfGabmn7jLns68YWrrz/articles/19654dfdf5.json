{"pageProps":{"article":{"id":"19654dfdf5","title":"在干部新年晚会上的讲话（摘录）","origin":"","is_range_date":false,"dates":[{"id":"837fd0f479","index":0,"year":1945,"month":1,"day":1,"articleId":"19654dfdf5"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"e23dcf99fa","name":"发言","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"b796fd677b","type":"title","text":"在干部新年晚会上的讲话（摘录）","index":0,"publicationId":"wansui2","articleId":"19654dfdf5"},{"id":"e4229a7ee8","type":"paragraph","text":"我们的任务是团结一切力量打倒日本帝国主义。过去我们早就实现了这个方针，今后更要加强它。共产党员，中国各阶层人民，国际反法西斯的朋友，都要更好的团结起来，我们团结得越好，则对于敌人的打击也越有力量。","index":1,"publicationId":"wansui2","articleId":"19654dfdf5"}],"page":{"id":"c0076514a1","publicationId":"wansui2","articleId":"19654dfdf5","start":88,"end":88}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"8708b1e187","title":"为瑞金红军烈士纪念碑写的碑文","origin":"","is_range_date":false,"dates":[{"id":"c7af6ec39e","index":0,"year":1934,"month":1,"day":15,"articleId":"8708b1e187"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"b5b86bce74","type":"title","text":"为瑞金红军烈士纪念碑写的碑文","index":0,"publicationId":"wansui2","articleId":"8708b1e187"},{"id":"44e3b59a70","type":"paragraph","text":"在反帝国主义与土地革命的伟大战斗中，许多同志光荣地牺牲了！这些同志牺牲，表现了无产阶级不可战胜的英勇，奠定了中华苏维埃共和国的基础，全中国工农劳苦群众，正在踏着这些同志的血迹前进，推翻帝国主义国民党的统治。争取苏维埃在全国的胜利。","index":1,"publicationId":"wansui2","articleId":"8708b1e187"},{"id":"5ee3be8085","type":"paragraph","text":"（原载一九五九年一月二十一日《解放军报》）","index":2,"publicationId":"wansui2","articleId":"8708b1e187"}],"page":{"id":"856a5521a0","publicationId":"wansui2","articleId":"8708b1e187","start":292,"end":293}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"76d68a113c","title":"给安吴青训班二周年纪念的题词","origin":"","is_range_date":false,"dates":[{"id":"e6c9bd40f2","index":0,"year":1939,"month":10,"day":null,"articleId":"76d68a113c"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"49b93e8b76","type":"title","text":"给安吴青训班二周年纪念的题词","index":0,"publicationId":"wansui2","articleId":"76d68a113c"},{"id":"e0d6336804","type":"paragraph","text":"带着新鲜血液与朝气加入革命队伍的青年们，无论是共产党员或非党员，都是可贵的，没有他们，革命队伍就不能发展，革命就不能胜利。但青年同志的自然的缺点是缺乏经验，而革命经验是必须亲身参加革命斗争，从最下层工作做起，切实地不带一点虚伪地经过若干年以后，经验就属于没有经验的人们了。","index":1,"publicationId":"wansui2","articleId":"76d68a113c"},{"id":"edcd3a759e","type":"paragraph","text":"（原载《毛泽东同志论青年和青年工作》，一九六○年中国青年出版社版第一○～一一页）","index":2,"publicationId":"wansui2","articleId":"76d68a113c"}],"page":{"id":"70d4b1be33","publicationId":"wansui2","articleId":"76d68a113c","start":459,"end":459}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"d0cb4d0afa","title":"非自杀（节录）","origin":"","is_range_date":false,"dates":[{"id":"749a4755f7","index":0,"year":1919,"month":11,"day":1,"articleId":"d0cb4d0afa"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui1","name":"毛泽东思想万岁(1913-1943卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui1a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui1":{"comments":[],"contents":[{"id":"4478c33b8b","type":"title","text":"非自杀（节录）","index":0,"publicationId":"wansui1","articleId":"d0cb4d0afa"},{"id":"a31a9cbeb8","type":"paragraph","text":"吾人应主张与社会奋斗。............反抗旧社全！与其自杀而死，宁奋斗被杀而亡。为目的达不到，截肠决战，玉碎而亡，则其天下之至刚至勇，而最足以印人脑府的了！","index":1,"publicationId":"wansui1","articleId":"d0cb4d0afa"},{"id":"6d70d8f8a1","type":"paragraph","text":"（原载长沙《大公报》，转抄自《光辉的五四》中国青年出版社一九五九年）","index":2,"publicationId":"wansui1","articleId":"d0cb4d0afa"}],"page":{"id":"160927f873","publicationId":"wansui1","articleId":"d0cb4d0afa","start":91,"end":91}}}},"__N_SSG":true}
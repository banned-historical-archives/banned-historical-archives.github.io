{"pageProps":{"article":{"id":"4700d01f94","title":"中共中央关于撤销军委办事组成立军委办公会议的通知","origin":"","is_range_date":false,"dates":[{"id":"580d929a7e","index":0,"year":1971,"month":10,"day":3,"articleId":"4700d01f94"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"318138ea26","name":"重要党政机构及其衍变","type":"主题"},{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"91736a0628","name":"中共中央通知","type":"发行机构"},{"id":"cce608ea44","name":"林彪","type":"主题"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"3588664dea","type":"title","text":"中共中央关于撤销军委办事组成立军委办公会议的通知","index":0,"publicationId":"wenku","articleId":"4700d01f94"},{"id":"219c28f28d","type":"paragraph","text":"毛主席批示：同意。","index":1,"publicationId":"wenku","articleId":"4700d01f94"},{"id":"2a302af756","type":"paragraph","text":"各大军区、各省军区、各野战军党委，各省、市、自治区党委，军委各总部、各军、兵种党委，中央和国务院各部、委领导小组和党的核心小组：","index":2,"publicationId":"wenku","articleId":"4700d01f94"},{"id":"51b0c1ab56","type":"paragraph","text":"中央决定，撤消军委办事组，成立军委办公会议。军委办公会议由军委副主席叶剑英同志主持，并由叶剑英、谢富治、张春桥、李先念、李德生、纪登奎、汪东兴、陈士榘、张才千、刘贤权十同志组成，即日成立，在中央军委领导下负责军委日常工作。特此通知。","index":3,"publicationId":"wenku","articleId":"4700d01f94"},{"id":"4a0462709d","type":"paragraph","text":"中共中央","index":4,"publicationId":"wenku","articleId":"4700d01f94"},{"id":"6611c2c905","type":"paragraph","text":"一九七一年十月三日","index":5,"publicationId":"wenku","articleId":"4700d01f94"}],"page":{"id":"20fe57759b","publicationId":"wenku","articleId":"4700d01f94","start":0,"end":0}}}},"__N_SSG":true}
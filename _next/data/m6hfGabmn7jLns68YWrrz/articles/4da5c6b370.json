{"pageProps":{"article":{"id":"4da5c6b370","title":"中共中央、国务院、中央军委、中央文革小组关于连云港事件的决定","origin":"","is_range_date":false,"dates":[{"id":"bd166d87e1","index":0,"year":1967,"month":12,"day":18,"articleId":"4da5c6b370"}],"tags":[{"id":"3bff1d2fc6","name":"暴力和武斗","type":"主题"},{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"cbee4acb80","name":"中共中央、国务院、中央军委、中央文革联发","type":"发行机构"},{"id":"d48f0ea3e8","name":"造反运动和派别斗争","type":"主题"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"215e75b261","type":"title","text":"中共中央、国务院、中央军委、中央文革小组关于连云港事件的决定","index":0,"publicationId":"wenku","articleId":"4da5c6b370"},{"id":"215ac0950f","type":"paragraph","text":"连云港市毛泽东主义人民公社、连云港市反到底总指挥部，6117部队、6066部队、连云港卫戍区司令部、283部队：","index":1,"publicationId":"wenku","articleId":"4da5c6b370"},{"id":"920e300288","type":"paragraph","text":"据报“毛泽东主义人民公社”今天又包围锦屏磷矿和化工厂，抢了部队的枪，民兵的枪，并打死打伤部队人员，曾先后的两次伏击解放军这种事件，这是完全错误的。接此电话后两派必须立即停止武斗，两派立即撤回原地并积极协助6117部队、6066部队，连云港卫戍区司令部、283部队，维护好社会革命秩序，保证港口、铁路运输正常。","index":2,"publicationId":"wenku","articleId":"4da5c6b370"},{"id":"8db66f6a08","type":"paragraph","text":"中共中央、国务院、中央军委、中央文革小组决定，由济南军区、山东省革命委员会派出郑统一为组长的调查组，到连云港就地进行调查了解情况和协助两派搞好革命的大批判、搞好革命的大联合、革命的三结合，斗、批、改，坚决响应伟大领袖毛主席的号召“要斗私，批修”。","index":3,"publicationId":"wenku","articleId":"4da5c6b370"},{"id":"97cdac09f6","type":"paragraph","text":"中共中央","index":4,"publicationId":"wenku","articleId":"4da5c6b370"},{"id":"731a0ca003","type":"paragraph","text":"国务院","index":5,"publicationId":"wenku","articleId":"4da5c6b370"},{"id":"f334215d8f","type":"paragraph","text":"中央军委","index":6,"publicationId":"wenku","articleId":"4da5c6b370"},{"id":"401734735a","type":"paragraph","text":"中央文革","index":7,"publicationId":"wenku","articleId":"4da5c6b370"},{"id":"8ede44b86a","type":"paragraph","text":"一九六七年十二月十八日","index":8,"publicationId":"wenku","articleId":"4da5c6b370"}],"page":{"id":"e90f755738","publicationId":"wenku","articleId":"4da5c6b370","start":0,"end":0}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"4107d6252b","title":"上海市红卫兵总部第一号通令","origin":"","is_range_date":false,"dates":[{"id":"fe65a43d1c","index":0,"year":1966,"month":9,"day":25,"articleId":"4107d6252b"}],"tags":[{"id":"3be4d5766f","name":"红卫兵运动","type":"主题"},{"id":"4bd6d6f93a","name":"群众运动重要文献","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"07cf0ecda6","name":"上海市红卫兵总部"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"f4aca6c204","type":"title","text":"上海市红卫兵总部第一号通令","index":0,"publicationId":"wenku","articleId":"4107d6252b"},{"id":"b13f268b6b","type":"paragraph","text":"上海市红卫兵总部第一号通令","index":1,"publicationId":"wenku","articleId":"4107d6252b"},{"id":"46f5fcc6fe","type":"paragraph","text":"1966.09.25","index":2,"publicationId":"wenku","articleId":"4107d6252b"},{"id":"d5559e37d8","type":"paragraph","text":"九月十二日上海市红卫兵总部成立以来，本市各区红卫兵总部相继成立。故本部决定凡上海市红卫兵总部所属的红卫兵战士于9月26日起换用统一袖章、旧袖章收缴。","index":3,"publicationId":"wenku","articleId":"4107d6252b"},{"id":"f4e559faa7","type":"paragraph","text":"上海市红卫兵总部所发袖章、红底黄字，统一印有“上海市红卫兵”字样，并盖有总部或区总部印章。","index":4,"publicationId":"wenku","articleId":"4107d6252b"},{"id":"07cc7e6760","type":"paragraph","text":"袖章式样：","index":5,"publicationId":"wenku","articleId":"4107d6252b"},{"id":"cecfead457","type":"paragraph","text":"上海市","index":6,"publicationId":"wenku","articleId":"4107d6252b"},{"id":"cd507cb6c9","type":"paragraph","text":"红卫兵","index":7,"publicationId":"wenku","articleId":"4107d6252b"},{"id":"4efb1224e5","type":"paragraph","text":"本部所属红卫兵袖章由本部统一发放，任何单位不得复制，违令者严加处理。","index":8,"publicationId":"wenku","articleId":"4107d6252b"}],"page":{"id":"773a076656","publicationId":"wenku","articleId":"4107d6252b","start":0,"end":0}}}},"__N_SSG":true}
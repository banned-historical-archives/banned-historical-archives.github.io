{"pageProps":{"article":{"id":"51c31ac2f9","title":"给英国海员工会三千华侨工友的复电","origin":"","is_range_date":false,"dates":[{"id":"20eb301ad3","index":0,"year":1946,"month":6,"day":26,"articleId":"51c31ac2f9"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"ace9b3d0a0","type":"title","text":"给英国海员工会三千华侨工友的复电","index":0,"publicationId":"wansui2","articleId":"51c31ac2f9"},{"id":"cb12c05c28","type":"paragraph","text":"邝××先生暨美国海员工会三千华侨工友：","index":1,"publicationId":"wansui2","articleId":"51c31ac2f9"},{"id":"b66e847855","type":"paragraph","text":"接获来电，得悉诸位工友呼吁立即停止中国内战，取消一党专政，成立民主联合政府，并对依靠外力进行内战的行为表示义愤。诸位关怀祖国前途，热爱和平民主，令人感佩兴奋。深望诸位再接再厉，唤起全美侨胞，全美劳工界与各界人士，要求美国当局立即停止对国民党独裁政府的任何援助，撤退驻华美国海陆空军，并撤销已向美国会提出的继续军事援华法案，使中国和平民主得以早日实现......","index":2,"publicationId":"wansui2","articleId":"51c31ac2f9"}],"page":{"id":"f15c6ea414","publicationId":"wansui2","articleId":"51c31ac2f9","start":172,"end":172}}}},"__N_SSG":true}
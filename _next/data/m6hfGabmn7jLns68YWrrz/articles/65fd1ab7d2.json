{"pageProps":{"article":{"id":"65fd1ab7d2","title":"中共中央关于成立中央专案组的通知","origin":"","is_range_date":false,"dates":[{"id":"1d9bf88bed","index":0,"year":1971,"month":10,"day":3,"articleId":"65fd1ab7d2"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"318138ea26","name":"重要党政机构及其衍变","type":"主题"},{"id":"91736a0628","name":"中共中央通知","type":"发行机构"},{"id":"cce608ea44","name":"林彪","type":"主题"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"4de78b90d5","type":"title","text":"中共中央关于成立中央专案组的通知","index":0,"publicationId":"wenku","articleId":"65fd1ab7d2"},{"id":"99791f3206","type":"paragraph","text":"毛主席批示：同意。","index":1,"publicationId":"wenku","articleId":"65fd1ab7d2"},{"id":"5639f0ce0b","type":"paragraph","text":"各大军区党委常委，各省、市、自治区党委常委，中央军委各总部、各军兵种党委常委，中央和国务院各部委领导小组和党的核心小组：","index":2,"publicationId":"wenku","articleId":"65fd1ab7d2"},{"id":"464c38be40","type":"paragraph","text":"为彻底审查、弄清林──陈反党集团的问题，中央决定成立中央专案组，集中处理有关问题。中央专案组由周恩来、康生、江青、张春桥、姚文元、纪登奎、李德生、汪东兴、吴德、吴忠十人组成。在专案组领导下，设立工作机构，由纪登奎、汪东兴两同志负责进行日常工作。各地、各单位今后凡向中央上报有关林──陈反党集团的揭发材料，统请以绝密亲启件送交中央专案组统一处理。","index":3,"publicationId":"wenku","articleId":"65fd1ab7d2"},{"id":"460fc19668","type":"paragraph","text":"中共中央","index":4,"publicationId":"wenku","articleId":"65fd1ab7d2"},{"id":"ab19a3b9cf","type":"paragraph","text":"一九七一年十月三日","index":5,"publicationId":"wenku","articleId":"65fd1ab7d2"}],"page":{"id":"661fe124c2","publicationId":"wenku","articleId":"65fd1ab7d2","start":0,"end":0}}}},"__N_SSG":true}
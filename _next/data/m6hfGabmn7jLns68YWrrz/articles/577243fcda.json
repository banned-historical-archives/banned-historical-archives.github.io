{"pageProps":{"article":{"id":"577243fcda","title":"戚本禹给北京市工代会农代会红代会的电话指示","origin":"","is_range_date":false,"dates":[{"id":"56b6e43b7c","index":0,"year":1967,"month":7,"day":21,"articleId":"577243fcda"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"3bff1d2fc6","name":"暴力和武斗","type":"主题"},{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"75d4111ddc","type":"title","text":"戚本禹给北京市工代会农代会红代会的电话指示","index":0,"publicationId":"wenku","articleId":"577243fcda"},{"id":"35d446f66f","type":"paragraph","text":"从现在开始，工代会、农代会、红代会马上开始游行，声援（武汉的）无产阶级革命派。","index":1,"publicationId":"wenku","articleId":"577243fcda"},{"id":"9e7299f68f","type":"paragraph","text":"“打倒‘百万雄师’！”，“打倒陈再道！”自己编些类似的口号。大会、小会、声讨会，从今天开始马上搞。今天下午，通知各院校，通知工代会到天安门活动，搞二至三天。","index":2,"publicationId":"wenku","articleId":"577243fcda"},{"id":"4f44196d86","type":"paragraph","text":"（引自1967.7.24清华大学《井冈山通讯》）","index":3,"publicationId":"wenku","articleId":"577243fcda"}],"page":{"id":"69b71f430b","publicationId":"wenku","articleId":"577243fcda","start":0,"end":0}}}},"__N_SSG":true}
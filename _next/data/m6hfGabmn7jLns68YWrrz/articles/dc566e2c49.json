{"pageProps":{"article":{"id":"dc566e2c49","title":"周恩来关于国务院各副总理分工问题的请示报告","origin":"","is_range_date":false,"dates":[{"id":"637376a52d","index":0,"year":1975,"month":2,"day":2,"articleId":"dc566e2c49"}],"tags":[{"id":"318138ea26","name":"重要党政机构及其衍变","type":"主题"},{"id":"523bb79e8f","name":"周恩来","type":"人物"},{"id":"a59dfa2519","name":"各级党政领导人","type":"主题"},{"id":"c0a0ee982d","name":"国务院文件","type":"发行机构"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"4755cb8c80","type":"title","text":"周恩来关于国务院各副总理分工问题的请示报告","index":0,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"6678997f2d","type":"paragraph","text":"〖注：此件是中央办公厅秘书局提供的周恩来手稿，毛泽东圈阅过。〗","index":1,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"310d4a6921","type":"paragraph","text":"中央政治局审阅后转呈主席批示","index":2,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"802df24328","type":"paragraph","text":"四届人大第一次会议闭幕后，政治局常委会上曾初步谈了国务院各副总理分工问题。后来，在政治局会上，洪文同志曾宣布国务院和中央军委常委的分工由各自议定后报中央、主席审批。","index":3,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"e1b768b0ec","type":"paragraph","text":"一九七五年二月一日，国务院召开总理、副总理十三人的常务会议，中央军委常务副主席叶剑英、科学院院长郭沫若两同志列席。会议审定国务院各副总理分工如下：","index":4,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"8ac7a63901","type":"paragraph","text":"一、邓小平：主管外事，在周恩来总理治病疗养期间，代总理主持会议和呈批主要文件；","index":5,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"1cc526d8ad","type":"paragraph","text":"张春桥：主管文化、教育；","index":6,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"672b74b951","type":"paragraph","text":"李先念：常务，主管财政、贸易；","index":7,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"ff0027b9c3","type":"paragraph","text":"陈锡联：主管国防工业和体育；","index":8,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"c5345f19de","type":"paragraph","text":"纪登奎：常务，主管劳动工资和干部调配；","index":9,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"6598387b00","type":"paragraph","text":"华国锋：常务，主管政法和科学；","index":10,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"33919f6c79","type":"paragraph","text":"陈永贵：主管农业；","index":11,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"1404d33098","type":"paragraph","text":"吴桂贤：主管卫生和轻工业；","index":12,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"36f3cf91f0","type":"paragraph","text":"王  震：主管交通和供销；","index":13,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"a0e60a3bed","type":"paragraph","text":"余秋里：主管计划和工业；","index":14,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"107835ee58","type":"paragraph","text":"谷  牧：主管建设和工业；","index":15,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"d79df07854","type":"paragraph","text":"孙  健：主管工业生产。","index":16,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"9a8e69d13b","type":"paragraph","text":"二、上述常务副总理（李、纪、华）三人负责处理国务院日常事务。","index":17,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"090097c33f","type":"paragraph","text":"三、上述两项分工得主席、中央批准后，即召开国务院全体会议在会上宣布，不另行文。","index":18,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"1d495bc9fe","type":"paragraph","text":"谨报，请予审批。","index":19,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"6ccc5e5dec","type":"paragraph","text":"周恩来","index":20,"publicationId":"wenku","articleId":"dc566e2c49"},{"id":"fc2c6115c4","type":"paragraph","text":"一九七五年二月二日","index":21,"publicationId":"wenku","articleId":"dc566e2c49"}],"page":{"id":"7fa02c8d8a","publicationId":"wenku","articleId":"dc566e2c49","start":0,"end":0}}}},"__N_SSG":true}
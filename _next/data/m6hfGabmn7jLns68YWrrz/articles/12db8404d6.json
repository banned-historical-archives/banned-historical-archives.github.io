{"pageProps":{"article":{"id":"12db8404d6","title":"康生对北京大学同学的讲话","origin":"","is_range_date":false,"dates":[{"id":"d30c48a856","index":0,"year":1966,"month":6,"day":5,"articleId":"12db8404d6"}],"tags":[{"id":"57eea82497","name":"康生","type":"人物"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"d48f0ea3e8","name":"造反运动和派别斗争","type":"主题"},{"id":"e23dcf99fa","name":"发言","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"8bb7755376","name":"康生"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"d914fbff8f","type":"title","text":"康生对北京大学同学的讲话","index":0,"publicationId":"wenku","articleId":"12db8404d6"},{"id":"1002302182","type":"paragraph","text":"1966年6月5日上午10点左右康老到北大看大字报时，在学生三食堂门前对北大革命师生说：","index":1,"publicationId":"wenku","articleId":"12db8404d6"},{"id":"eafb53aa42","type":"paragraph","text":"同学们！我看了你们的大字报，很高兴。有你们这些革命的同学，什么牛鬼蛇神、什么彭真、什么陆定一、什么罗瑞卿、什么陆平、什么彭佩云都统统被打倒！","index":2,"publicationId":"wenku","articleId":"12db8404d6"},{"id":"a8fdd8325f","type":"paragraph","text":"中国共产党万岁！","index":3,"publicationId":"wenku","articleId":"12db8404d6"},{"id":"cd64fd0573","type":"paragraph","text":"毛主席万岁！万岁！万万岁！","index":4,"publicationId":"wenku","articleId":"12db8404d6"}],"page":{"id":"54feffe8d0","publicationId":"wenku","articleId":"12db8404d6","start":0,"end":0}}}},"__N_SSG":true}
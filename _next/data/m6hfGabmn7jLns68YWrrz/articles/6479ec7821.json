{"pageProps":{"article":{"id":"6479ec7821","title":"红卫兵战歌（歌词）","origin":"","is_range_date":false,"dates":[{"id":"47cc230e78","index":0,"year":1966,"month":8,"day":1,"articleId":"6479ec7821"}],"tags":[{"id":"3be4d5766f","name":"红卫兵运动","type":"主题"},{"id":"3bff1d2fc6","name":"暴力和武斗","type":"主题"},{"id":"4bd6d6f93a","name":"群众运动重要文献","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"7f8ac6a0df","name":"清华大学附属中学红卫兵"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"497be8e0b4","type":"title","text":"红卫兵战歌（歌词）","index":0,"publicationId":"wenku","articleId":"6479ec7821"},{"id":"1be9a91045","type":"paragraph","text":"红卫兵战歌（歌词）","index":1,"publicationId":"wenku","articleId":"6479ec7821"},{"id":"2175c71617","type":"paragraph","text":"清华大学附属中学红卫兵","index":2,"publicationId":"wenku","articleId":"6479ec7821"},{"id":"d77d3134fb","type":"paragraph","text":"1966.08.01","index":3,"publicationId":"wenku","articleId":"6479ec7821"},{"id":"b74579a66e","type":"paragraph","text":"先辈血战创江山，革命后代来接班。跟着领袖毛泽东，造反小将千千万。誓死保卫党中央，誓死保卫毛主席，大风大浪英勇奋战，高歌猛进杀向前。","index":4,"publicationId":"wenku","articleId":"6479ec7821"},{"id":"c1460988ac","type":"paragraph","text":"纵横南北红卫兵，牛鬼蛇神心胆寒。毛泽东思想红战旗，世世代代永相传。造反！造反！造反！敢叫日月换新天！杀！","index":5,"publicationId":"wenku","articleId":"6479ec7821"},{"id":"f9c43b4349","type":"paragraph","text":"红卫兵创作","index":6,"publicationId":"wenku","articleId":"6479ec7821"},{"id":"6cc1c0e1b4","type":"paragraph","text":"1966.8.1","index":7,"publicationId":"wenku","articleId":"6479ec7821"}],"page":{"id":"c17a0fb071","publicationId":"wenku","articleId":"6479ec7821","start":0,"end":0}}}},"__N_SSG":true}
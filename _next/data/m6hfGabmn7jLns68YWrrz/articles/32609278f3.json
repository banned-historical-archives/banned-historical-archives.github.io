{"pageProps":{"article":{"id":"32609278f3","title":"八连颂","origin":"","is_range_date":false,"dates":[{"id":"ee349756b4","index":0,"year":1963,"month":8,"day":1,"articleId":"32609278f3"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"3527fd4011","type":"title","text":"八连颂","index":0,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"e9a1cc74ac","type":"paragraph","text":"好八连，天下传。","index":1,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"2e6198c47c","type":"paragraph","text":"为什么，意志坚。","index":2,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"6e03de3359","type":"paragraph","text":"为人民，几十年。","index":3,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"b8f2e0eb81","type":"paragraph","text":"拒腐蚀，永不沾。","index":4,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"9be2e2b707","type":"paragraph","text":"因此叫，好八连。","index":5,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"221772703c","type":"paragraph","text":"解放军，要学习，","index":6,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"6f937cfa4e","type":"paragraph","text":"全军民，要自立。","index":7,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"ed580bd0f0","type":"paragraph","text":"不怕压，不怕迫，","index":8,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"09c75cfe4e","type":"paragraph","text":"不怕刀，不怕戟，","index":9,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"bdb64e1351","type":"paragraph","text":"不怕鬼，不怕魅，","index":10,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"1fe36c859d","type":"paragraph","text":"不怕帝，不怕贼。","index":11,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"0cb1095d30","type":"paragraph","text":"奇儿女，如松柏。","index":12,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"03718322ab","type":"paragraph","text":"上参天，傲霜雪。","index":13,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"d21570cbd5","type":"paragraph","text":"纪律好，如坚壁。","index":14,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"e9256329d4","type":"paragraph","text":"军事好，如霹雳。","index":15,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"5d5d8390dd","type":"paragraph","text":"政治好，称第一。","index":16,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"8c33143792","type":"paragraph","text":"思想好，能分析。","index":17,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"a7be643188","type":"paragraph","text":"分析好，大有益。","index":18,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"cf4fbdc25c","type":"paragraph","text":"益在哪？团结力。","index":19,"publicationId":"wansui5","articleId":"32609278f3"},{"id":"2053b26c65","type":"paragraph","text":"军民团结如一人，试看天下谁能敌。","index":20,"publicationId":"wansui5","articleId":"32609278f3"}],"page":{"id":"b3eb61e593","publicationId":"wansui5","articleId":"32609278f3","start":122,"end":123}}}},"__N_SSG":true}
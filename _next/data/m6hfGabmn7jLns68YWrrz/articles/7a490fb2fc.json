{"pageProps":{"article":{"id":"7a490fb2fc","title":"中共中央对被批判斗争对象的工资处理问题的通知","origin":"","is_range_date":false,"dates":[{"id":"df06f96a5c","index":0,"year":1966,"month":9,"day":18,"articleId":"7a490fb2fc"}],"tags":[{"id":"23d8fa5fb1","name":"知识分子与社会名流","type":"主题"},{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"3df4ae75e1","name":"干部和干部政策","type":"主题"},{"id":"91736a0628","name":"中共中央通知","type":"发行机构"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"a5f4b4cfc9","type":"title","text":"中共中央对被批判斗争对象的工资处理问题的通知","index":0,"publicationId":"wenku","articleId":"7a490fb2fc"},{"id":"1b7235c6af","type":"paragraph","text":"吉林省委并东北局，各中央局：","index":1,"publicationId":"wenku","articleId":"7a490fb2fc"},{"id":"17562fd7ce","type":"paragraph","text":"吉林省委九月十六日电悉。对被批判斗争对象的工资处理意见，即使已定性的，也暂不改变，如本人少领工资，或捐献一部分工资作党费，听其自愿，但不强求，也不许其由减少用费而致病；私人东西，除政治性的，一般不查抄；凡未定性的，工资仍照旧。","index":2,"publicationId":"wenku","articleId":"7a490fb2fc"}],"page":{"id":"a2db573002","publicationId":"wenku","articleId":"7a490fb2fc","start":0,"end":0}}}},"__N_SSG":true}
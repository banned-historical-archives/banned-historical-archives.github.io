{"pageProps":{"article":{"id":"6799b9cebd","title":"中共中央关于夺权斗争宣传报导问题的通知","origin":"","is_range_date":false,"dates":[{"id":"1094e75186","index":0,"year":1967,"month":2,"day":19,"articleId":"6799b9cebd"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"714adabb18","name":"夺权和一月革命","type":"主题"},{"id":"91736a0628","name":"中共中央通知","type":"发行机构"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"874daf310d","type":"title","text":"中共中央关于夺权斗争宣传报导问题的通知","index":0,"publicationId":"wenku","articleId":"6799b9cebd"},{"id":"c61b57bc8e","type":"paragraph","text":"各级党委：","index":1,"publicationId":"wenku","articleId":"6799b9cebd"},{"id":"ccf08dbb8a","type":"paragraph","text":"关于各省、市、自治区夺权斗争的宣传报导问题，中央作如下规定：","index":2,"publicationId":"wenku","articleId":"6799b9cebd"},{"id":"0b0c7cf50d","type":"paragraph","text":"（一）各省、市、自治区领导夺权斗争的临时权力机构，叫什么名称？是不是真正做到三结合（即由真正代表广大群众的革命群众组织的负责人、人民解放军当地驻军的代表、党政机关真正有代表性的革命领导干部组成的），今后要先报告中央，经中央批准后，再在当地报纸上发表。","index":3,"publicationId":"wenku","articleId":"6799b9cebd"},{"id":"af1de0c9af","type":"paragraph","text":"（二）各省、市、自治区和各城市的政权组织形式，除对上海中央另有指示外，一般的不要采用人民公社的名称。","index":4,"publicationId":"wenku","articleId":"6799b9cebd"},{"id":"e8c637eed1","type":"paragraph","text":"中共中央","index":5,"publicationId":"wenku","articleId":"6799b9cebd"},{"id":"b54719aa7e","type":"paragraph","text":"一九六七年二月十九日","index":6,"publicationId":"wenku","articleId":"6799b9cebd"}],"page":{"id":"b1547d3276","publicationId":"wenku","articleId":"6799b9cebd","start":0,"end":0}}}},"__N_SSG":true}
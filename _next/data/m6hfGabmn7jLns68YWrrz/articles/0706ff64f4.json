{"pageProps":{"article":{"id":"0706ff64f4","title":"《中国革命战争的战略问题》出版按语","origin":"","is_range_date":false,"dates":[{"id":"f7f853402c","index":0,"year":1941,"month":2,"day":23,"articleId":"0706ff64f4"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"80fb49f843","type":"title","text":"《中国革命战争的战略问题》出版按语","index":0,"publicationId":"wansui2","articleId":"0706ff64f4"},{"id":"722da210d9","type":"paragraph","text":"这本小书是一九三六年秋季作为当时红军大学的教本而写的，目的在总结内战的经验。只完成五章，留有战略进攻，战略转移，政治工作，及其他许多问题没有工夫再写了。四年来只有油印本，兹应军政杂志社之请，用铅印出版，籍供党内同志参考。这是一场大争论的结果，是表示一个路线反对另一个路线的意见，对于目前的抗日战争还是有用的。","index":1,"publicationId":"wansui2","articleId":"0706ff64f4"},{"id":"83753b4656","type":"subdate","text":"一九四一年二月二十三日","index":2,"publicationId":"wansui2","articleId":"0706ff64f4"},{"id":"4fd76edc76","type":"paragraph","text":"（《毛泽东选集》东北书店一九四八年版第五八五页）","index":3,"publicationId":"wansui2","articleId":"0706ff64f4"}],"page":{"id":"598883efb9","publicationId":"wansui2","articleId":"0706ff64f4","start":461,"end":462}}}},"__N_SSG":true}
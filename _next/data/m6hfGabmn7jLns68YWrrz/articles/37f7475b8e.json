{"pageProps":{"article":{"id":"37f7475b8e","title":"在边区中央局经济自给动员大会上的讲话","origin":"","is_range_date":false,"dates":[{"id":"243edb71e4","index":0,"year":1940,"month":12,"day":3,"articleId":"37f7475b8e"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"e23dcf99fa","name":"发言","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui1","name":"毛泽东思想万岁(1913-1943卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui1a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui1":{"comments":[],"contents":[{"id":"7bca37aaff","type":"title","text":"在边区中央局经济自给动员大会上的讲话","index":0,"publicationId":"wansui1","articleId":"37f7475b8e"},{"id":"0a84e9a1e3","type":"paragraph","text":"毛泽东同志在讲话中指出现在根据地的工作粗枝大叶已经不行了，必须以细密的组织工作来代替，经济建设的任务就是适应现在的环境而提出的。接着他说要细心地待人接物，仔细地认识自己周围的人物，具体地分别地对待他们，团结他们，这样才能使革命走向胜利，我们今天进行的经济建设，也要懂得这个道理，孤家寡人是什么也干不成的。","index":1,"publicationId":"wansui1","articleId":"37f7475b8e"}],"page":{"id":"998e8cbdda","publicationId":"wansui1","articleId":"37f7475b8e","start":510,"end":510}}}},"__N_SSG":true}
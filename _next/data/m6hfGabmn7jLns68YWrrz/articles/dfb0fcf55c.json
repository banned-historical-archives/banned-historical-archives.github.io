{"pageProps":{"article":{"id":"dfb0fcf55c","title":"给抗大九队同志的信","origin":"","is_range_date":false,"dates":[{"id":"4055ebd7eb","index":0,"year":1937,"month":12,"day":25,"articleId":"dfb0fcf55c"}],"tags":[{"id":"2a70b5d939","name":"书信","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui1","name":"毛泽东思想万岁(1913-1943卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui1a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui1":{"comments":[],"contents":[{"id":"8e7555723c","type":"title","text":"给抗大九队同志的信","index":0,"publicationId":"wansui1","articleId":"dfb0fcf55c"},{"id":"36e02ee9cd","type":"paragraph","text":"九队同志们：","index":1,"publicationId":"wansui1","articleId":"dfb0fcf55c"},{"id":"25c1642ff8","type":"paragraph","text":"庆祝你们成立了救亡室，这救亡二字就是你们及全国人民在现阶段上唯一的总目标。达到这个目标的道路是抗日民族统一战线，希望你们学习这个统一战线的理论与方法，唯有统一战线方能达到救亡的目的。","index":2,"publicationId":"wansui1","articleId":"dfb0fcf55c"},{"id":"233fa5d288","type":"paragraph","text":"毛泽东","index":3,"publicationId":"wansui1","articleId":"dfb0fcf55c"},{"id":"c219b47653","type":"subdate","text":"十二月二十五日","index":4,"publicationId":"wansui1","articleId":"dfb0fcf55c"}],"page":{"id":"5092ed7fe1","publicationId":"wansui1","articleId":"dfb0fcf55c","start":393,"end":393}}}},"__N_SSG":true}
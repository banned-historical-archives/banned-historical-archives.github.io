{"pageProps":{"article":{"id":"404fe0a8eb","title":"李富春关于批判余秋里的指示","origin":"","is_range_date":false,"dates":[{"id":"72c321538a","index":0,"year":1967,"month":8,"day":30,"articleId":"404fe0a8eb"}],"tags":[{"id":"25e2abfb25","name":"李富春","type":"人物"},{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"83b1479e48","name":"重要党内斗争和案件","type":"主题"},{"id":"a59dfa2519","name":"各级党政领导人","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"9c4175f9ee","name":"李富春"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"e533eac1d1","type":"title","text":"李富春关于批判余秋里的指示","index":0,"publicationId":"wenku","articleId":"404fe0a8eb"},{"id":"1cfc59fdcd","type":"paragraph","text":"八月卅日上午九点廿分，总理联络员电话传达李富春同志关于批判余秋里的指示：","index":1,"publicationId":"wenku","articleId":"404fe0a8eb"},{"id":"84502f6c20","type":"paragraph","text":"每周可以批判两次。","index":2,"publicationId":"wenku","articleId":"404fe0a8eb"},{"id":"90f53dd820","type":"paragraph","text":"第一：计委革命造反“公社”一派星期三，计委红委会星期六。","index":3,"publicationId":"wenku","articleId":"404fe0a8eb"},{"id":"eb37211d79","type":"paragraph","text":"第二：每次不超过三小时。","index":4,"publicationId":"wenku","articleId":"404fe0a8eb"},{"id":"263d949a51","type":"paragraph","text":"第三：只许文斗，不许武斗。","index":5,"publicationId":"wenku","articleId":"404fe0a8eb"},{"id":"8223e366ec","type":"paragraph","text":"第四：批完后按时送回国务院，不许扣人。","index":6,"publicationId":"wenku","articleId":"404fe0a8eb"}],"page":{"id":"aab9328728","publicationId":"wenku","articleId":"404fe0a8eb","start":0,"end":0}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"125a152ac1","title":"对一渡河支部提拔新生力量报导的指示","origin":"","is_range_date":false,"dates":[{"id":"e44672968e","index":0,"year":1964,"month":7,"day":4,"articleId":"125a152ac1"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"0d79aa5f25","type":"title","text":"对一渡河支部提拔新生力量报导的指示","index":0,"publicationId":"wansui5","articleId":"125a152ac1"},{"id":"53beaa604b","type":"paragraph","text":"主席看了七月四日人民日报二版关于一渡河党支部培养青年干部的报导，当日作如下指示：","index":1,"publicationId":"wansui5","articleId":"125a152ac1"},{"id":"03ff7e515a","type":"paragraph","text":"×××同志，怀柔县一渡河支部提拔新生力量的做法，各省可能都有，要广泛采访，转载，在几年之内做到每县每社每个工厂、学校、机关都有报导。但要是真实的，典型的。固步自封的反面材料，也要登一点。这个问题，报社和通讯社应当讨论一下。并与各省、市、区联系，要他们也一样做。","index":2,"publicationId":"wansui5","articleId":"125a152ac1"},{"id":"242c5da43b","type":"paragraph","text":"毛泽东","index":3,"publicationId":"wansui5","articleId":"125a152ac1"},{"id":"33d35b4453","type":"subdate","text":"七月四日","index":4,"publicationId":"wansui5","articleId":"125a152ac1"}],"page":{"id":"ef8da2ca50","publicationId":"wansui5","articleId":"125a152ac1","start":271,"end":271}}}},"__N_SSG":true}
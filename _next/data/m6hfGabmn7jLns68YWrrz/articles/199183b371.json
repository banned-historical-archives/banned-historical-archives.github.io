{"pageProps":{"article":{"id":"199183b371","title":"关于湖南军区的龙书金","origin":"","is_range_date":false,"dates":[{"id":"d4eb9d8823","index":0,"year":1967,"month":7,"day":null,"articleId":"199183b371"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"f9e70916f5","type":"title","text":"关于湖南军区的龙书金","index":0,"publicationId":"wansui5","articleId":"199183b371"},{"id":"0570a071aa","type":"paragraph","text":"这个人是否还可以用？你们要讲究斗争策略，你们水平怎么这么低，也不研究一下。据我了解，这个人打仗很勇敢我对打仗很勇敢的人还是很尊重的。他犯了错误当然可以批判，但既然他表示愿意改，就应给他机会，不要太过分。你们这样做，不能争取别人同情。","index":1,"publicationId":"wansui5","articleId":"199183b371"}],"page":{"id":"ce6da013ac","publicationId":"wansui5","articleId":"199183b371","start":616,"end":616}}}},"__N_SSG":true}
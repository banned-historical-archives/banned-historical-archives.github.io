{"pageProps":{"article":{"id":"a1569e9eaa","title":"陶铸给广西自治区党委的电报","origin":"","is_range_date":false,"dates":[{"id":"5d5633a09c","index":0,"year":1966,"month":9,"day":11,"articleId":"a1569e9eaa"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"d48f0ea3e8","name":"造反运动和派别斗争","type":"主题"},{"id":"d5cbd05390","name":"通讯","type":"文稿类型"},{"id":"dbcf15bd08","name":"陶铸","type":"人物"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"489fec27f2","name":"陶铸"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"696a7f50b1","type":"title","text":"陶铸给广西自治区党委的电报","index":0,"publicationId":"wenku","articleId":"a1569e9eaa"},{"id":"eeba31a5ca","type":"paragraph","text":"广西自治区党委并告南宁、桂林地区革命师生同志们！","index":1,"publicationId":"wenku","articleId":"a1569e9eaa"},{"id":"eb59267f73","type":"paragraph","text":"现在向大家申明一下，我对绝食问题的看法：我在接见来京学生时，没有谈到绝食问题。说我讲过“静座、绝食不仅是革命行动，而且是伟大的创举，”这纯属谣传。绝食我是不赞成的，为什么要绝食、把身体弄坏呢？应当爱护身体，吃饱饭，按十六条更好地进行斗争。","index":2,"publicationId":"wenku","articleId":"a1569e9eaa"},{"id":"c7198904d7","type":"paragraph","text":"（加急分送两份：桂林地委、桂林市委。）","index":3,"publicationId":"wenku","articleId":"a1569e9eaa"},{"id":"39a19e20a8","type":"paragraph","text":"陶铸","index":4,"publicationId":"wenku","articleId":"a1569e9eaa"},{"id":"a83b81c998","type":"paragraph","text":"一九六六年九月十一日","index":5,"publicationId":"wenku","articleId":"a1569e9eaa"}],"page":{"id":"e2cb3214a6","publicationId":"wenku","articleId":"a1569e9eaa","start":0,"end":0}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"9be1ac290e","title":"给内蒙人民代表大会的贺电","origin":"","is_range_date":false,"dates":[{"id":"375cb2cf87","index":0,"year":1947,"month":5,"day":19,"articleId":"9be1ac290e"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"ef0f789fca","type":"title","text":"给内蒙人民代表大会的贺电","index":0,"publicationId":"wansui2","articleId":"9be1ac290e"},{"id":"1d3c84676b","type":"paragraph","text":"亲爱的内蒙人民代表大会全体代表们：","index":1,"publicationId":"wansui2","articleId":"9be1ac290e"},{"id":"002b4256ca","type":"paragraph","text":"你们五月十七日来电收到了。曾经饱受困难的内蒙同胞在你们领导之下，正在开始创造自由光明的新历史。我们相信：内蒙民族将与汉族和其他民族亲密团结，为着扫除民族压迫与封建压迫，建设新蒙古与新中国而奋斗。庆祝你们的胜利。","index":2,"publicationId":"wansui2","articleId":"9be1ac290e"},{"id":"98e1999f92","type":"paragraph","text":"（《人民日报》一九四七年五月二十二日）","index":3,"publicationId":"wansui2","articleId":"9be1ac290e"}],"page":{"id":"dbb59cd7f7","publicationId":"wansui2","articleId":"9be1ac290e","start":179,"end":179}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"f6ea269ce8","title":"同×××谈人民日报要学习解放军","origin":"","is_range_date":false,"dates":[{"id":"3aa315851a","index":0,"year":1964,"month":1,"day":8,"articleId":"f6ea269ce8"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"c76ecf5653","type":"title","text":"同×××谈人民日报要学习解放军","index":0,"publicationId":"wansui5","articleId":"f6ea269ce8"},{"id":"5872fbb278","type":"paragraph","text":"人民日报要学习解放军。","index":1,"publicationId":"wansui5","articleId":"f6ea269ce8"},{"id":"196ddeb58f","type":"paragraph","text":"新闻工作要学习解放军。","index":2,"publicationId":"wansui5","articleId":"f6ea269ce8"},{"id":"aecee662f0","type":"paragraph","text":"人民日报要看一下林总对解放军报的意见。","index":3,"publicationId":"wansui5","articleId":"f6ea269ce8"},{"id":"cb6fe44ff3","type":"paragraph","text":"学习解放军，学习石油部，主要学习他们怎样抓思想政治工作。","index":4,"publicationId":"wansui5","articleId":"f6ea269ce8"},{"id":"44816accd2","type":"paragraph","text":"文汇报、解放日报在这方面，很可以看看。他们把政治思想工作的纲抓起来了。","index":5,"publicationId":"wansui5","articleId":"f6ea269ce8"},{"id":"00923ab836","type":"paragraph","text":"人民日报要注意发表学术性文章，发表历史、哲学和其他学术文章。","index":6,"publicationId":"wansui5","articleId":"f6ea269ce8"},{"id":"42d0f931b5","type":"paragraph","text":"抓哲学，要抓活哲学。我写文章不大引用马克思、列宁怎么说。报纸老引我的话，引来引去，我就不舒服。应该学会用自己的话来写文章。列宁就很少引人家的话，而用自己的话写文章。当然不是说不要引人家的话，是说不要处处都引。","index":7,"publicationId":"wansui5","articleId":"f6ea269ce8"}],"page":{"id":"92450edd6f","publicationId":"wansui5","articleId":"f6ea269ce8","start":161,"end":161}}}},"__N_SSG":true}
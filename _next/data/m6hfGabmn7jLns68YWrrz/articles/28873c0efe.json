{"pageProps":{"article":{"id":"28873c0efe","title":"中央文革关于学习两报一刊社论的通知","origin":"","is_range_date":false,"dates":[{"id":"9775e3c0e2","index":0,"year":1968,"month":5,"day":5,"articleId":"28873c0efe"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"91736a0628","name":"中共中央通知","type":"发行机构"},{"id":"c1c0033e04","name":"指导理论","type":"主题"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"185320de67","type":"title","text":"中央文革关于学习两报一刊社论的通知","index":0,"publicationId":"wenku","articleId":"28873c0efe"},{"id":"b4f67b9f5a","type":"paragraph","text":"中央两报一刊重要社论《革命委员会好》，以及《人民日报》，《解放军报》，在庆祝湖南，安徽革命委员会成立时的社论“芙蓉国里尽朝晖”，“无产阶级革命派的胜利”，红旗杂志评论员文章“对派性要进行阶级分析”，“五一”社论“乘胜前进”，传达了毛主席的一系列的最新指示，总结了革命委员会的经验，指出了无产阶级文化大革命的方向。望各级革命委员会，各革命群众组织，人民解放军指战员以及一切的毛泽东思想学习班，认真组织学习和讨论，使无产阶级文化大革命运动，按照毛主席的无产阶级革命路线和最新指示，继续胜利前进。","index":1,"publicationId":"wenku","articleId":"28873c0efe"},{"id":"1051a4dd6f","type":"paragraph","text":"中央文化革命小组","index":2,"publicationId":"wenku","articleId":"28873c0efe"},{"id":"0482e8cee9","type":"paragraph","text":"一九六八年五月五日","index":3,"publicationId":"wenku","articleId":"28873c0efe"}],"page":{"id":"d59ded81e8","publicationId":"wenku","articleId":"28873c0efe","start":0,"end":0}}}},"__N_SSG":true}
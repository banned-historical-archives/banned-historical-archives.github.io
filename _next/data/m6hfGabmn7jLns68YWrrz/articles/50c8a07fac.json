{"pageProps":{"article":{"id":"50c8a07fac","title":"对学习毛主席最新指示的指示","origin":"","is_range_date":false,"dates":[{"id":"58e73164f9","index":0,"year":1967,"month":9,"day":6,"articleId":"50c8a07fac"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"eb3ed1b86b","name":"个人崇拜","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"f326d8be5e","name":"林彪"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"3a1b928171","type":"title","text":"对学习毛主席最新指示的指示","index":0,"publicationId":"wenku","articleId":"50c8a07fac"},{"id":"5125710f91","type":"paragraph","text":"毛主席的指示是马克思列宁主义的伟大历史文献。是对一年多以来无产阶级文化大革命最科学、最完整、最精辟、最透彻的总结。是指引全党、全国、全军奋勇前进的灯塔，是保证无产阶级文化大革命取得彻底胜利的最新最强大的思想武器，全军必须坚决照办，句句照办，字字照办。","index":1,"publicationId":"wenku","articleId":"50c8a07fac"}],"page":{"id":"4a31db3bda","publicationId":"wenku","articleId":"50c8a07fac","start":0,"end":0}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"1b5cce8e26","title":"对《人民日报加强学术文章的报告》的批示","origin":"","is_range_date":false,"dates":[{"id":"f2e16d7806","index":0,"year":1964,"month":2,"day":3,"articleId":"1b5cce8e26"}],"tags":[{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"98c8f273f3","type":"title","text":"对《人民日报加强学术文章的报告》的批示","index":0,"publicationId":"wansui5","articleId":"1b5cce8e26"},{"id":"72e3aa2cdc","type":"paragraph","text":"××、××同志：","index":1,"publicationId":"wansui5","articleId":"1b5cce8e26"},{"id":"9ab92112c8","type":"paragraph","text":"《人民日报》历来不重视思想理论工作，哲学社会科学文章很少，把这个理论阵地送给《光明日报》、《文汇报》和《新建设》月刊。这种情况必须改变过来才好。现在他们有了改的主意了，请书记处讨论一下，并给他们解决干部问题为盼。","index":2,"publicationId":"wansui5","articleId":"1b5cce8e26"}],"page":{"id":"6fb2d8a285","publicationId":"wansui5","articleId":"1b5cce8e26","start":178,"end":179}}}},"__N_SSG":true}
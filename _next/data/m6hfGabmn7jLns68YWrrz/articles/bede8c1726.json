{"pageProps":{"article":{"id":"bede8c1726","title":"关于军队整训的指示——给林彪同志的信","origin":"","is_range_date":false,"dates":[{"id":"3bc61be728","index":0,"year":1967,"month":5,"day":7,"articleId":"bede8c1726"}],"tags":[{"id":"2a70b5d939","name":"书信","type":"文稿类型"},{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"e9793eaf32","type":"title","text":"关于军队整训的指示——给林彪同志的信","index":0,"publicationId":"wansui5","articleId":"bede8c1726"},{"id":"d806ef2d3f","type":"paragraph","text":"林彪同志：","index":1,"publicationId":"wansui5","articleId":"bede8c1726"},{"id":"f3322ac0b6","type":"paragraph","text":"各地军队都应整训一个短时期，时间 10——14 天为宜，已经整训过的，一个月或三个月再整训一次，全军三支两军人员，每一个月或两个月，都应整训一次，发扬成绩，纠正错误，以利再战。","index":2,"publicationId":"wansui5","articleId":"bede8c1726"}],"page":{"id":"dd6ce8ec0b","publicationId":"wansui5","articleId":"bede8c1726","start":591,"end":591}}}},"__N_SSG":true}
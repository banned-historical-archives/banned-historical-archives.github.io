{"pageProps":{"article":{"id":"7a64c75848","title":"关于文艺要推陈出新","origin":"","is_range_date":false,"dates":[{"id":"f241b63db1","index":0,"year":1963,"month":9,"day":27,"articleId":"7a64c75848"}],"tags":[{"id":"5387dec24b","name":"文学艺术","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"e2305b9e63","name":"毛泽东","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"26aaaf9765","type":"title","text":"关于文艺要推陈出新","index":0,"publicationId":"wenku","articleId":"7a64c75848"},{"id":"467d41b863","type":"paragraph","text":"文艺部门、戏曲、电影方面也要抓一下推陈出新的问题，舞台上尽是帝王将相、家丁、丫环。内容变了，形式也要变，如水袖等等。推陈出新，出什么？封建主义？社会主义？旧形式要出新内容。按这个样子，二十年后就没有人看了。上层建筑总要适应经济基础。","index":1,"publicationId":"wenku","articleId":"7a64c75848"}],"page":{"id":"2e4454a8b3","publicationId":"wenku","articleId":"7a64c75848","start":0,"end":0}}}},"__N_SSG":true}
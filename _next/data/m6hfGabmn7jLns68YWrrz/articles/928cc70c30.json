{"pageProps":{"article":{"id":"928cc70c30","title":"关于军队要协同地方管工业的指示","origin":"","is_range_date":false,"dates":[{"id":"dbedc410af","index":0,"year":1967,"month":3,"day":3,"articleId":"928cc70c30"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"73b1b91de0","type":"title","text":"关于军队要协同地方管工业的指示","index":0,"publicationId":"wansui5","articleId":"928cc70c30"},{"id":"3b4ab91775","type":"paragraph","text":"此件可印发军级会议各同志。军队不但要协同地方管农业，对工业也要管。沈阳军区派遣大批人员进厂做宣传和做调查的办法是很多的。××军在无锡、××军在重庆、××军在伊春、苇河等处也有好的经验。总之，军队不能坐视工业生产下降而置之不理。","index":1,"publicationId":"wansui5","articleId":"928cc70c30"}],"page":{"id":"057388a4cd","publicationId":"wansui5","articleId":"928cc70c30","start":566,"end":567}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"b42b998035","title":"中央军委规定","origin":"","is_range_date":false,"dates":[{"id":"066d05c5fc","index":0,"year":1967,"month":2,"day":8,"articleId":"b42b998035"}],"tags":[{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"d125b2a9b6","name":"中央军委文件","type":"发行机构"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"c7af287558","type":"title","text":"中央军委规定","index":0,"publicationId":"wenku","articleId":"b42b998035"},{"id":"a3df8e527f","type":"paragraph","text":"一，海军，空军，飞行航校，各军以下单位一律不搞四大，进行正面教育。","index":1,"publicationId":"wenku","articleId":"b42b998035"},{"id":"a0aa3d3d02","type":"paragraph","text":"二，海军舰队，机关和各军区，空军领导机关暂不搞四大，什么时间，另行通知。","index":2,"publicationId":"wenku","articleId":"b42b998035"},{"id":"e87d5a543b","type":"paragraph","text":"望各单位遵照执行。","index":3,"publicationId":"wenku","articleId":"b42b998035"},{"id":"609361dc09","type":"paragraph","text":"中央军委","index":4,"publicationId":"wenku","articleId":"b42b998035"}],"page":{"id":"30f7e24e06","publicationId":"wenku","articleId":"b42b998035","start":0,"end":0}}}},"__N_SSG":true}
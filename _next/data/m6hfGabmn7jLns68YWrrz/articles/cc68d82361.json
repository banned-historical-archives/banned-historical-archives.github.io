{"pageProps":{"article":{"id":"cc68d82361","title":"《海瑞罢官》的要害是罢官","origin":"","is_range_date":false,"dates":[{"id":"b6c81a093c","index":0,"year":1966,"month":2,"day":8,"articleId":"cc68d82361"}],"tags":[{"id":"5387dec24b","name":"文学艺术","type":"主题"},{"id":"aed7beab98","name":"《海瑞罢官》","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"e2305b9e63","name":"毛泽东","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"3fa5a092ae","type":"title","text":"《海瑞罢官》的要害是罢官","index":0,"publicationId":"wenku","articleId":"cc68d82361"},{"id":"5fc5e87a1e","type":"paragraph","text":"吴晗的《海瑞罢官》的要害是罢官，是同庐山会议、同彭德怀的右倾机会主义有关的。对资产阶级意识形态的斗争，是长期的阶级斗争，绝不是匆促做一个政治结论就可以解决的。","index":1,"publicationId":"wenku","articleId":"cc68d82361"},{"id":"4d5beb594b","type":"paragraph","text":"（彭真说要对左派“整风”）这样的问题，三年以后再说。","index":2,"publicationId":"wenku","articleId":"cc68d82361"}],"page":{"id":"8a3e29c836","publicationId":"wenku","articleId":"cc68d82361","start":0,"end":0}}}},"__N_SSG":true}
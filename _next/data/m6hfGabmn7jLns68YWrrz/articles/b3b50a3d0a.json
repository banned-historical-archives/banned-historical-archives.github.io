{"pageProps":{"article":{"id":"b3b50a3d0a","title":"红军第四军司令部布告","origin":"","is_range_date":false,"dates":[{"id":"5942092eb3","index":0,"year":1929,"month":null,"day":null,"articleId":"b3b50a3d0a"}],"tags":[{"id":"5bfa9ca15d","name":"宣言","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui1","name":"毛泽东思想万岁(1913-1943卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui1a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui1":{"comments":[],"contents":[{"id":"54143d665f","type":"title","text":"红军第四军司令部布告","index":0,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"a33079fe86","type":"paragraph","text":"红军宗旨，民权革命，赣西一军，声威远震。","index":1,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"b846dbd00a","type":"paragraph","text":"此番计划，分矢前进，辅佐民夫，服从命令。","index":2,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"5476931804","type":"paragraph","text":"平买平卖，事实为证，乱烧乱杀，在所必禁。","index":3,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"167dd843da","type":"paragraph","text":"全国各地，压迫太甚，工人农人，十分痛苦。","index":4,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"70b711defc","type":"paragraph","text":"土豪劣绅，横行乡镇，重息要租，人人悲愤。","index":5,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"b987e5f25b","type":"paragraph","text":"白军士兵，饥寒交并，小资产者，捐税极重。","index":6,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"a73699151b","type":"paragraph","text":"洋债越多，国债受困，帝国主义，哪个不恨。","index":7,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"c652c61646","type":"paragraph","text":"国民匪党，完全反动，口是心非，不能过硬。","index":8,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"4a037e9292","type":"paragraph","text":"蒋桂冯阎，同床异梦，冲突已起，军阀倒运。","index":9,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"f764b7c725","type":"paragraph","text":"饭可充饥，药可医病，共产主张，极为公正。","index":10,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"6353dc524a","type":"paragraph","text":"地主田地，农民收种，债不要还，租不要送。","index":11,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"59df05296a","type":"paragraph","text":"增加工钱，老板担任，八时工作，恰好相称。","index":12,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"1ca9b0ea34","type":"paragraph","text":"军人待遇，必须改订，发给田地，士兵有份。","index":13,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"fdac5a4e32","type":"paragraph","text":"敌方士兵，可以投顺，以前行动，可以不问。","index":14,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"97571f4092","type":"paragraph","text":"累进税法，最为适用，苛捐杂税，扫除一净。","index":15,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"2dd488d9e5","type":"paragraph","text":"城市商人，积珠累财，只要服从，余昔不论。","index":16,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"54a550009f","type":"paragraph","text":"对待外人，必须严峻，工厂银行，没收归并。","index":17,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"ceb244951e","type":"paragraph","text":"外资外债，概不承认，外兵外舰，不准入境。","index":18,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"c43d67e462","type":"paragraph","text":"打倒列强，人人高兴，打倒军阀，除恶务尽。","index":19,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"735610ed09","type":"paragraph","text":"统一中华，举国称庆，满蒙回藏，章程自定。","index":20,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"0ac3aaa9dd","type":"paragraph","text":"国民政府，一群恶棍，合力铲除，肃清乱政。","index":21,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"c52f45c314","type":"paragraph","text":"全国工农，风发雷奋，夺取政权，为期日近。","index":22,"publicationId":"wansui1","articleId":"b3b50a3d0a"},{"id":"16d0f552a9","type":"paragraph","text":"革命成功，尽在民众，布告四方，大家起劲。","index":23,"publicationId":"wansui1","articleId":"b3b50a3d0a"}],"page":{"id":"75d4a456b9","publicationId":"wansui1","articleId":"b3b50a3d0a","start":212,"end":213}}}},"__N_SSG":true}
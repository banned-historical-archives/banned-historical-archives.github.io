{"pageProps":{"article":{"id":"018de09979","title":"周恩来在一份军委政治部报送的文件上的批示","origin":"","is_range_date":false,"dates":[{"id":"26a9363b1c","index":0,"year":1967,"month":10,"day":11,"articleId":"018de09979"}],"tags":[{"id":"523bb79e8f","name":"周恩来","type":"人物"},{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"7a204c8255","type":"title","text":"周恩来在一份军委政治部报送的文件上的批示","index":0,"publicationId":"wenku","articleId":"018de09979"},{"id":"27290e1be9","type":"paragraph","text":"军委有关日常行政、部队调遣、干部任免、部队编组、武器装备等非属三支两军和国防外交范围的请示报告和批件，应由军委和总参直报林副主席批，不需经我手转报。此事请军委常委一议，报林副主席转报主席批准。否则，压在我处文件太多，无时处理，而且超越权限，贻误大事。","index":1,"publicationId":"wenku","articleId":"018de09979"}],"page":{"id":"6ad436cfc6","publicationId":"wenku","articleId":"018de09979","start":0,"end":0}}}},"__N_SSG":true}
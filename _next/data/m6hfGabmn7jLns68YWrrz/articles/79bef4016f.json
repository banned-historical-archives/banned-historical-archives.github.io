{"pageProps":{"article":{"id":"79bef4016f","title":"关于江青不要下去“蹲点”等问题的批语","origin":"","is_range_date":false,"dates":[{"id":"963d3d51c4","index":0,"year":1975,"month":10,"day":27,"articleId":"79bef4016f"}],"tags":[{"id":"264b63d816","name":"四人帮","type":"主题"},{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"e2305b9e63","name":"毛泽东","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"88c19d5bef","type":"title","text":"关于江青不要下去“蹲点”等问题的批语","index":0,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"44398651db","type":"paragraph","text":"关于江青不要下去“蹲点”等问题的批语","index":1,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"058a3bc912","type":"paragraph","text":"毛泽东","index":2,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"c9386739cb","type":"paragraph","text":"1975. 10. 27","index":3,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"2f9461245c","type":"paragraph","text":"改一改，","index":4,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"3be89c995d","type":"paragraph","text":"不要蹲点。","index":5,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"b3ae01f5c5","type":"paragraph","text":"军队、地方都不要蹲点，","index":6,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"2e2e5ffd5c","type":"paragraph","text":"特别在北京，","index":7,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"ee73b24cbf","type":"paragraph","text":"我在北京没有去个（过）任何一个地方，","index":8,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"6cc22f1523","type":"paragraph","text":"说话不要冲口而出。","index":9,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"ac09bf1e70","type":"paragraph","text":"不要管，","index":10,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"6b6c020362","type":"paragraph","text":"要顾大局，","index":11,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"e732273333","type":"paragraph","text":"不要打电话，","index":12,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"7778985df4","type":"paragraph","text":"不要来看我，","index":13,"publicationId":"wenku","articleId":"79bef4016f"},{"id":"23b3c44e5f","type":"paragraph","text":"有事写信。","index":14,"publicationId":"wenku","articleId":"79bef4016f"}],"page":{"id":"1388a40dbf","publicationId":"wenku","articleId":"79bef4016f","start":0,"end":0}}}},"__N_SSG":true}
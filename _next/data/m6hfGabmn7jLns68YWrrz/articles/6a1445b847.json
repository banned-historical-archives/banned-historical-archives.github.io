{"pageProps":{"article":{"id":"6a1445b847","title":"中央关于武汉“七·二O事件”给武汉军区党委的复电","origin":"","is_range_date":false,"dates":[{"id":"6c53a68925","index":0,"year":1967,"month":7,"day":25,"articleId":"6a1445b847"}],"tags":[{"id":"6f7a683373","name":"军队和军事","type":"主题"},{"id":"83b1479e48","name":"重要党内斗争和案件","type":"主题"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"},{"id":"e2305b9e63","name":"毛泽东","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"93dc7a5905","type":"title","text":"中央关于武汉“七·二O事件”给武汉军区党委的复电","index":0,"publicationId":"wenku","articleId":"6a1445b847"},{"id":"b7d8f7bab0","type":"paragraph","text":"中共武汉军区党委：","index":1,"publicationId":"wenku","articleId":"6a1445b847"},{"id":"9b48e2a157","type":"paragraph","text":"七月二十四日二十时十分来电并所附武汉部队公告全文已经收到。中央进行了讨论。认为（一）你们现在所采取的立场和政策是正确的。公告可以发表。（二）对于犯了严重错误的干部，包括你们和广大革命群众所要打倒的陈再道同志在内，只要他们不再坚持错误，认真改正，并为广大革命群众所谅解了之后，仍然可以站起来，参加革命行列。（三）要向思想不通的某些部队人员和百万雄师做工作，使他们转变过来。（四）要向左派做工作，不要乘机报复。（五）要警惕坏人捣乱，不许破坏社会秩序。","index":2,"publicationId":"wenku","articleId":"6a1445b847"}],"page":{"id":"c628f0c4c7","publicationId":"wenku","articleId":"6a1445b847","start":0,"end":0}}}},"__N_SSG":true}
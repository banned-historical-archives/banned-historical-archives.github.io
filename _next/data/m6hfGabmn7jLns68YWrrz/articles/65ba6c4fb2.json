{"pageProps":{"article":{"id":"65ba6c4fb2","title":"中共中央关于邓小平参加中央领导工作的通知","origin":"","is_range_date":false,"dates":[{"id":"dc8983ab8a","index":0,"year":1973,"month":12,"day":22,"articleId":"65ba6c4fb2"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"318138ea26","name":"重要党政机构及其衍变","type":"主题"},{"id":"91736a0628","name":"中共中央通知","type":"发行机构"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"},{"id":"fb776baaf9","name":"邓小平","type":"主题"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"fda2b291f2","type":"title","text":"中共中央关于邓小平参加中央领导工作的通知","index":0,"publicationId":"wenku","articleId":"65ba6c4fb2"},{"id":"7faeed1011","type":"paragraph","text":"各省、市、自冶区党委，各大军区、省军区、各野战军党委，军委各总部、各军、兵种党委，中央、国家机关各部、委领导小组或党的核心小组：","index":1,"publicationId":"wenku","articleId":"65ba6c4fb2"},{"id":"66cfb4b4d9","type":"paragraph","text":"遵照毛主席的提议，中央决定：邓小平同志为中央政治局委员，参加中央领导工作，待十届二中全会开会时请予追认；邓小平同志为中央军事会委员，参加军委领导工作。","index":2,"publicationId":"wenku","articleId":"65ba6c4fb2"},{"id":"5efbe0016f","type":"paragraph","text":"特此通知","index":3,"publicationId":"wenku","articleId":"65ba6c4fb2"}],"page":{"id":"c4ffd19b95","publicationId":"wenku","articleId":"65ba6c4fb2","start":0,"end":0}}}},"__N_SSG":true}
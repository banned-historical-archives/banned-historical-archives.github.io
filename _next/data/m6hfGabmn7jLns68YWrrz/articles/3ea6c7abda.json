{"pageProps":{"article":{"id":"3ea6c7abda","title":"一九四七年三月十八日撤离延安时的讲话","origin":"","is_range_date":false,"dates":[{"id":"c939f6a4fd","index":0,"year":1947,"month":3,"day":18,"articleId":"3ea6c7abda"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"e23dcf99fa","name":"发言","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"7695748e78","type":"title","text":"一九四七年三月十八日撤离延安时的讲话","index":0,"publicationId":"wansui2","articleId":"3ea6c7abda"},{"id":"8cb7dc1f37","type":"paragraph","text":"一九四七年三月十八日撤离延安时敌人越来越近十几里枪炮声都可以听到，机关群众都已陆续撤走，大家劝主席快走，主席讲：不要紧，来得及，大路朝天一人半边，他走他的，他们到那个山头，我就到这个山头，怕什么，没有什么可怕的。","index":1,"publicationId":"wansui2","articleId":"3ea6c7abda"}],"page":{"id":"6c87df5c7b","publicationId":"wansui2","articleId":"3ea6c7abda","start":178,"end":178}}}},"__N_SSG":true}
{"pageProps":{"article":{"id":"930429afb6","title":"在志丹陵园红星纪念塔上的题词","origin":"","is_range_date":false,"dates":[{"id":"c4b8e40772","index":0,"year":1943,"month":null,"day":null,"articleId":"930429afb6"}],"tags":[{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wansui2","name":"毛泽东思想万岁(1943-1949卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui2a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui2":{"comments":[],"contents":[{"id":"c303e79e5d","type":"title","text":"在志丹陵园红星纪念塔上的题词","index":0,"publicationId":"wansui2","articleId":"930429afb6"},{"id":"05464afe6a","type":"paragraph","text":"我到陕北，和刘志丹同志见过一面。就知道他是一个很好的共产党员，他的英勇牺牲，出于意外，但他的忠心耿耿，为党为国的精神，是永远留在党与人民中间，而不会磨灭的。","index":1,"publicationId":"wansui2","articleId":"930429afb6"},{"id":"dc63b3ca97","type":"paragraph","text":"（原载《解放日报》一九四三年五月六日）","index":2,"publicationId":"wansui2","articleId":"930429afb6"}],"page":{"id":"ace14dd495","publicationId":"wansui2","articleId":"930429afb6","start":541,"end":541}}}},"__N_SSG":true}
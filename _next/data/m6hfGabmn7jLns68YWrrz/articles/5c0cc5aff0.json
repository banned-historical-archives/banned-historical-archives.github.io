{"pageProps":{"article":{"id":"5c0cc5aff0","title":"对四位外国专家的大字报的批示","origin":"","is_range_date":false,"dates":[{"id":"3a8888876b","index":0,"year":1966,"month":8,"day":29,"articleId":"5c0cc5aff0"}],"tags":[{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui5","name":"毛泽东思想万岁(1961-1968卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui5a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui5":{"comments":[],"contents":[{"id":"8436b36695","type":"title","text":"对四位外国专家的大字报的批示","index":0,"publicationId":"wansui5","articleId":"5c0cc5aff0"},{"id":"edc9a6c1f8","type":"paragraph","text":"我同意这张大字报，外国革命专家及其孩子要同中国人完全一样，不许两样。请你们考虑一下，凡自愿的，一律同样做。如何，请酌定。","index":1,"publicationId":"wansui5","articleId":"5c0cc5aff0"}],"page":{"id":"57c053cb7f","publicationId":"wansui5","articleId":"5c0cc5aff0","start":519,"end":519}}}},"__N_SSG":true}
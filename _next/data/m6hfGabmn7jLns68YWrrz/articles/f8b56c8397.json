{"pageProps":{"article":{"id":"f8b56c8397","title":"对志愿军党委的指示（摘录）","origin":"","is_range_date":false,"dates":[],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wansui3","name":"毛泽东思想万岁(1949-1957卷)","internal":false,"official":false,"type":"pdf","author":"未知","files":"/books/wansui3a.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"wansui3":{"comments":[],"contents":[{"id":"b9e59fcc39","type":"title","text":"对志愿军党委的指示（摘录）","index":0,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"0cc6dff3ff","type":"paragraph","text":"我中国人民志愿军进入朝鲜境内，必须对朝鲜人民、朝鲜人民军、朝鲜民主政府、朝鲜劳动党、及其它民主党派，及朝鲜人民领袖金日成同志表示友谊和尊重，严格地遵守军事纪律和政治纪律，这是保证完成军事任务的一个极重要的政治基础。","index":1,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"deed5fc243","type":"paragraph","text":"（中国革命军事博物馆展出）","index":2,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"94a0f7d9d2","type":"paragraph","text":"对中国人民志愿军指示的团结朝鲜人民四项原则","index":3,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"062d7d600a","type":"paragraph","text":"对中国人民志愿军指示的团结朝鲜人民四项原则：","index":4,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"caa522181a","type":"paragraph","text":"一、拥护朝鲜劳动党，朝鲜人民共和国金日成首相;","index":5,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"06eed10ee4","type":"paragraph","text":"二、严格遵守朝鲜政府的政策命令；","index":6,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"4886ef5d43","type":"paragraph","text":"三、爱护朝鲜人民利益；","index":7,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"e0c99333ba","type":"paragraph","text":"四、以自我批评的精神．检查缺点，增进团结。","index":8,"publicationId":"wansui3","articleId":"f8b56c8397"},{"id":"78698d8c7b","type":"paragraph","text":"（中国革命军事博物馆展出）","index":9,"publicationId":"wansui3","articleId":"f8b56c8397"}],"page":{"id":"e7cacd2dba","publicationId":"wansui3","articleId":"f8b56c8397","start":27,"end":28}}}},"__N_SSG":true}
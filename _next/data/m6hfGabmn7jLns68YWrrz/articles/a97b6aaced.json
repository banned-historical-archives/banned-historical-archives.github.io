{"pageProps":{"article":{"id":"a97b6aaced","title":"中央转发云南省委关于严禁村政权浪费的指示的批语","origin":"","is_range_date":false,"dates":[{"id":"11a989d0bf","index":0,"year":1950,"month":5,"day":14,"articleId":"a97b6aaced"}],"tags":[{"id":"2d13338754","name":"指示","type":"文稿类型"},{"id":"9bc2c334c7","name":"批示","type":"文稿类型"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"}],"aliases":[],"publications":[{"id":"maoquanji28","name":"毛泽东全集第28卷","internal":false,"official":true,"type":"pdf","author":"张迪杰","files":"https://raw.githubusercontent.com/banned-historical-archives/banned-historical-archives0/main/mao-quanji/28-OCR.pdf"}],"authors":[{"id":"261e5467ec","name":"毛泽东"}]},"publication_details":{"maoquanji28":{"comments":[],"contents":[{"id":"c9e4a501d5","type":"title","text":"中央转发云南省委关于严禁村政权浪费的指示的批语","index":0,"publicationId":"maoquanji28","articleId":"a97b6aaced"},{"id":"f4f2e312f2","type":"paragraph","text":"各中央局、分局，并转各省委、区党委、直属市姿：","index":1,"publicationId":"maoquanji28","articleId":"a97b6aaced"},{"id":"d8d4997c49","type":"paragraph","text":"村经费支用浪费是一极严重现象，云南省委发了严禁指示，西南局已通知所属遵行。望各地检查此事，按照情况采行为盼。","index":2,"publicationId":"maoquanji28","articleId":"a97b6aaced"},{"id":"88bec91076","type":"subtitle","text":"中央","index":3,"publicationId":"maoquanji28","articleId":"a97b6aaced"},{"id":"b0b706abd4","type":"paragraph","text":"五月十四日","index":4,"publicationId":"maoquanji28","articleId":"a97b6aaced"}],"page":{"id":"34204783b2","publicationId":"maoquanji28","articleId":"a97b6aaced","start":391,"end":391}}}},"__N_SSG":true}
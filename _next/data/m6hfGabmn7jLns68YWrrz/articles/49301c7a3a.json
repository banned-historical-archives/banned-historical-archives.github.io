{"pageProps":{"article":{"id":"49301c7a3a","title":"中共中央（周恩来）给吉林师大红卫兵组织的一封电报","origin":"","is_range_date":false,"dates":[{"id":"0c772f5f09","index":0,"year":1966,"month":11,"day":30,"articleId":"49301c7a3a"}],"tags":[{"id":"3df4ae75e1","name":"干部和干部政策","type":"主题"},{"id":"a59dfa2519","name":"各级党政领导人","type":"主题"},{"id":"b4f67da172","name":"中共中央电报","type":"发行机构"},{"id":"d5cbd05390","name":"通讯","type":"文稿类型"},{"id":"ef6e778547","name":"中央文件","type":"文稿大类"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"de5951fbbf","type":"title","text":"中共中央（周恩来）给吉林师大红卫兵组织的一封电报","index":0,"publicationId":"wenku","articleId":"49301c7a3a"},{"id":"6b95ebeb56","type":"paragraph","text":"来电均悉。关于赵林同志出狱的问题，中央于一九六六年十一月二十六日电复东北局并吉林省委，请他们向南开大学八·一八红卫兵和其他革命同学说明：“他们揭发赵林同志出狱的问题，中央是知道的。如果他们有新的材料，可派代表送来中央查处，不要在大会上公布和追查。”","index":1,"publicationId":"wenku","articleId":"49301c7a3a"},{"id":"19924bbdfa","type":"paragraph","text":"希望你们按照中央上述电示执行。如果你们还发现新的材料和线索可以继续查清，并将新的材料派代表送来中央查处。希望你们不要在群众大会上公布和追查，也不要散发传单，涂写标语。","index":2,"publicationId":"wenku","articleId":"49301c7a3a"}],"page":{"id":"81aef42f0d","publicationId":"wenku","articleId":"49301c7a3a","start":0,"end":0}}}},"__N_SSG":true}
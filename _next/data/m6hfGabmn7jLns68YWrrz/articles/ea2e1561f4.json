{"pageProps":{"article":{"id":"ea2e1561f4","title":"戚本禹给聂元梓蒯大富的电话记录","origin":"","is_range_date":false,"dates":[{"id":"74b0f8603c","index":0,"year":1967,"month":2,"day":13,"articleId":"ea2e1561f4"}],"tags":[{"id":"18bf6a78fe","name":"大联合","type":"主题"},{"id":"57434e107b","name":"戚本禹","type":"人物"},{"id":"c20d333791","name":"关键人物文稿","type":"文稿大类"},{"id":"c9f57d6426","name":"文章","type":"文稿类型"}],"aliases":[],"publications":[{"id":"wenku","name":"中国文化大革命文库(第一版)","internal":false,"official":false,"type":"db","author":"宋永毅","files":""}],"authors":[{"id":"9014e20fdf","name":"戚本禹"}]},"publication_details":{"wenku":{"comments":[],"contents":[{"id":"02c8308def","type":"title","text":"戚本禹给聂元梓蒯大富的电话记录","index":0,"publicationId":"wenku","articleId":"ea2e1561f4"},{"id":"709188d3b8","type":"paragraph","text":"聂、蒯同志：","index":1,"publicationId":"wenku","articleId":"ea2e1561f4"},{"id":"d8327afa7a","type":"paragraph","text":"关于北京造反公社情况我不了解，他们的代表们曾找过我，因为抽不出时间，一直未能见到。我曾表示过，希望北京革命组织，在毛泽东思想基础上搞大联合，不要搞小团体主义。所传我们对造反公社的批评，如果指的这个意思，是有的。但是，这不是批评，而是一种愿望。另外，大联合组织，是否用“北京公社”的名义，希望你们商量一下。","index":2,"publicationId":"wenku","articleId":"ea2e1561f4"},{"id":"166ff22eee","type":"paragraph","text":"祝你们在毛泽东思想基础上联合起来。","index":3,"publicationId":"wenku","articleId":"ea2e1561f4"},{"id":"ea2018f6b1","type":"paragraph","text":"戚本禹","index":4,"publicationId":"wenku","articleId":"ea2e1561f4"},{"id":"ce31d52891","type":"paragraph","text":"一九六七年二月十三日","index":5,"publicationId":"wenku","articleId":"ea2e1561f4"}],"page":{"id":"7a4e417d14","publicationId":"wenku","articleId":"ea2e1561f4","start":0,"end":0}}}},"__N_SSG":true}